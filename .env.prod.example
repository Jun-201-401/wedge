# Application image tags built on the EC2 host by Jenkins CD.
API_SERVER_IMAGE=wedge-api-server:deploy-local
WEB_IMAGE=wedge-web:deploy-local

# Nginx public ingress
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# PostgreSQL
POSTGRES_USER=wedge_app
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=wedge

# RabbitMQ
RABBITMQ_USER=wedge_app
RABBITMQ_PASSWORD=change-me-rabbitmq-password
WEDGE_RUNNER_MQ_EXCHANGE=wedge.direct
WEDGE_RUN_EXECUTE_QUEUE=run.execute.request

# AWS credentials for private S3 artifact storage.
# Keep real access keys only in the EC2 .env.prod file.
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=change-me-aws-access-key-id
AWS_SECRET_ACCESS_KEY=change-me-aws-secret-access-key

# API server artifact content storage.
WEDGE_ARTIFACT_STORAGE=s3
WEDGE_ARTIFACT_BUCKET=wedge-artifacts-prod

# Runner artifact upload storage.
# filesystem: store artifacts on the local container/host filesystem.
# s3: upload artifacts to AWS S3.
RUNNER_ARTIFACT_STORAGE=s3
RUNNER_ARTIFACT_BUCKET=wedge-artifacts-prod
RUNNER_ARTIFACT_PREFIX=runs

# Spring / internal security
JWT_SECRET=change-me-jwt-secret-at-least-32-characters
INTERNAL_SERVICE_TOKEN=change-me-internal-service-token
