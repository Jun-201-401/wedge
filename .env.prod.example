# Application image tags are release metadata.
# Do not keep API_SERVER_IMAGE, WEB_IMAGE, RUNNER_IMAGE, or ANALYZER_IMAGE here.
# Jenkins writes them to .deploy/current.env after a verified production deployment.

# Nginx public ingress
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# PostgreSQL
POSTGRES_USER=wedge_app
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=wedge

# Flyway database migration
FLYWAY_IMAGE=redgate/flyway:12.6.0

# RabbitMQ
RABBITMQ_USER=wedge_app
RABBITMQ_PASSWORD=change-me-rabbitmq-password
WEDGE_RUNNER_MQ_EXCHANGE=wedge.direct
WEDGE_RUN_EXECUTE_QUEUE=run.execute.request
WEDGE_AGENT_EXECUTE_QUEUE=agent.execute.request
WEDGE_DISCOVERY_EXECUTE_QUEUE=discovery.execute.request
WEDGE_SCENARIO_AUTHORING_EXECUTE_QUEUE=scenario-authoring.execute.request
WEDGE_ANALYSIS_REQUEST_QUEUE=analysis.request

# AWS credentials for private S3 artifact storage.
# Keep real access keys only in the EC2 .env.prod file.
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=change-me-aws-access-key-id
AWS_SECRET_ACCESS_KEY=change-me-aws-secret-access-key

# API server artifact content storage.
WEDGE_ARTIFACT_STORAGE=s3
WEDGE_ARTIFACT_BUCKET=wedge-artifacts-prod

# Runner artifact upload storage.
# filesystem: store artifacts on the local container/host filesystem.
# s3: upload artifacts to AWS S3.
RUNNER_ARTIFACT_STORAGE=s3
RUNNER_ARTIFACT_BUCKET=wedge-artifacts-prod

# Runner MQ concurrency and duplicate-delivery protection.
# Keep prefetch low per runner replica for long-running browser work; increase replicas first.
RUNNER_MQ_PREFETCH=1
RUNNER_AGENT_CONCURRENCY=1
RUNNER_MESSAGE_IDEMPOTENCY_STORE_MODE=api
RUNNER_AGENT_IDEMPOTENCY_STORE_MODE=api
RUNNER_AGENT_IDEMPOTENCY_LEASE_TTL_MS=300000
RUNNER_AGENT_IDEMPOTENCY_RENEW_INTERVAL_MS=60000
RUNNER_MQ_REQUEUE_ON_FAILURE=false
RUNNER_MQ_MAX_DELIVERY_ATTEMPTS=3

# Analyzer worker
ANALYZER_MQ_PREFETCH=1
ANALYZER_GMS_ENABLED=false
ANALYZER_GMS_API_KEY=change-me-gms-api-key
ANALYZER_GMS_MODEL=gpt-4.1-nano
ANALYZER_GMS_BASE_URL=https://gms.ssafy.io/gmsapi
ANALYZER_GMS_OPENAI_RESPONSES_PATH=api.openai.com/v1/responses
ANALYZER_GMS_TIMEOUT_SECONDS=20

# Runner agent decision client.
# heuristic: default rule-based decision client.
# llm: call the configured LLM endpoint, then still pass decisions through verifier/policy.
# mcp: wait for an MCP Host to resolve pending decisions through API Server.
RUNNER_AGENT_DECISION_MODE=heuristic
RUNNER_AGENT_LLM_ENDPOINT=https://gms.ssafy.io/gmsapi/api.openai.com/v1/chat/completions
RUNNER_AGENT_LLM_API_KEY=change-me-gms-api-key
RUNNER_AGENT_LLM_MODEL=gpt-4.1-nano
RUNNER_AGENT_LLM_TIMEOUT_MS=20000
RUNNER_AGENT_MCP_GATEWAY_URL=http://api-server:8080/internal/agent/mcp/decision
RUNNER_AGENT_MCP_SERVICE_TOKEN=change-me-internal-service-token
RUNNER_AGENT_MCP_GATEWAY_TIMEOUT_MS=180000

# Spring / internal security
JWT_SECRET=change-me-jwt-secret-at-least-32-characters
INTERNAL_SERVICE_TOKEN=change-me-internal-service-token
INTERNAL_RUNNER_CALLBACK_SIGNATURE_SECRET=change-me-runner-callback-signature-secret

# MCP server
# Disabled by default. Enable only after MCP authentication and tool authorization are ready.
WEDGE_MCP_SERVER_ENABLED=false
WEDGE_MCP_SERVICE_TOKEN=change-me-mcp-service-token
WEDGE_MCP_PENDING_DECISION_TTL=PT5M
