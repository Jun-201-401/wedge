# Application image tag built on the EC2 host by Jenkins CD.
API_SERVER_IMAGE=wedge-api-server:deploy-local

# Public ingress port exposed by nginx in compose.prod.yaml.
NGINX_EXTERNAL_PORT=18080

# PostgreSQL
POSTGRES_USER=wedge_app
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=wedge

# Spring / internal security
JWT_SECRET=change-me-jwt-secret-at-least-32-characters
INTERNAL_SERVICE_TOKEN=change-me-internal-service-token
