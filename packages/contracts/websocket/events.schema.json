{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wedge.example.com/contracts/websocket/events.schema.json",
  "title": "Wedge WebSocket Events",
  "oneOf": [
    {
      "$ref": "#/$defs/RunStatusChangedEvent"
    },
    {
      "$ref": "#/$defs/StepStartedEvent"
    },
    {
      "$ref": "#/$defs/StepFinishedEvent"
    },
    {
      "$ref": "#/$defs/CheckpointCreatedEvent"
    },
    {
      "$ref": "#/$defs/LatestFrameAvailableEvent"
    },
    {
      "$ref": "#/$defs/IssueSignalDetectedEvent"
    },
    {
      "$ref": "#/$defs/AnalysisStartedEvent"
    },
    {
      "$ref": "#/$defs/AnalysisFinishedEvent"
    },
    {
      "$ref": "#/$defs/RunFailedEvent"
    },
    {
      "$ref": "#/$defs/DiscoveryStatusChangedEvent"
    },
    {
      "$ref": "#/$defs/DiscoveryCheckpointCreatedEvent"
    },
    {
      "$ref": "#/$defs/ScenarioRecommendationsReadyEvent"
    }
  ],
  "$defs": {
    "RunStatusChangedEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string"
        },
        "eventType": {
          "const": "run_status_changed"
        },
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "CREATED",
                "QUEUED",
                "STARTING",
                "RUNNING",
                "STOP_REQUESTED",
                "STOPPED",
                "COMPLETED",
                "FAILED"
              ]
            },
            "resultCompleteness": {
              "type": "string",
              "enum": [
                "NONE",
                "PARTIAL",
                "FINAL"
              ]
            },
            "analysisStatus": {
              "type": "string",
              "enum": [
                "NOT_STARTED",
                "QUEUED",
                "RUNNING",
                "COMPLETED",
                "FAILED"
              ]
            },
            "currentStepOrder": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 1
            },
            "scenarioFitStatus": {
              "type": "string",
              "enum": [
                "UNKNOWN",
                "APPLICABLE",
                "LOW_CONFIDENCE",
                "NOT_APPLICABLE",
                "BLOCKED_BY_SITE",
                "UNSAFE_OR_RESTRICTED"
              ]
            },
            "scenarioFitReason": {
              "type": [
                "string",
                "null"
              ]
            },
            "scenarioFitSummary": {
              "type": [
                "object",
                "null"
              ],
              "additionalProperties": true
            }
          },
          "required": [
            "status",
            "resultCompleteness",
            "analysisStatus"
          ]
        }
      },
      "required": [
        "eventId",
        "eventType",
        "runId",
        "occurredAt",
        "payload"
      ]
    },
    "StepStartedEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string"
        },
        "eventType": {
          "const": "step_started"
        },
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "stepId": {
              "type": "string",
              "format": "uuid"
            },
            "stepKey": {
              "type": "string"
            },
            "stepOrder": {
              "type": "integer",
              "minimum": 1
            },
            "stepName": {
              "type": "string",
              "minLength": 1
            },
            "stage": {
              "enum": [
                "FIRST_VIEW",
                "VALUE",
                "CTA",
                "INPUT",
                "COMMIT"
              ]
            },
            "description": {
              "type": "string"
            }
          },
          "required": [
            "stepId",
            "stepOrder"
          ]
        }
      },
      "required": [
        "eventId",
        "eventType",
        "runId",
        "occurredAt",
        "payload"
      ]
    },
    "StepFinishedEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string"
        },
        "eventType": {
          "const": "step_finished"
        },
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "stepId": {
              "type": "string",
              "format": "uuid"
            },
            "stepOrder": {
              "type": "integer",
              "minimum": 1
            },
            "status": {
              "type": "string",
              "enum": [
                "PENDING",
                "RUNNING",
                "PASSED",
                "FAILED",
                "SKIPPED",
                "BLOCKED",
                "STOPPED"
              ]
            },
            "durationMs": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            }
          },
          "required": [
            "stepId",
            "stepOrder",
            "status"
          ]
        }
      },
      "required": [
        "eventId",
        "eventType",
        "runId",
        "occurredAt",
        "payload"
      ]
    },
    "CheckpointCreatedEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string"
        },
        "eventType": {
          "const": "checkpoint_created"
        },
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "checkpointId": {
              "type": "string"
            },
            "checkpointKey": {
              "type": "string"
            },
            "stepId": {
              "type": "string",
              "format": "uuid"
            },
            "stage": {
              "enum": [
                "FIRST_VIEW",
                "VALUE",
                "CTA",
                "INPUT",
                "COMMIT"
              ]
            },
            "observationCount": {
              "type": "integer",
              "minimum": 0
            },
            "artifactRefs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "checkpointId",
            "stepId",
            "stage",
            "observationCount"
          ]
        }
      },
      "required": [
        "eventId",
        "eventType",
        "runId",
        "occurredAt",
        "payload"
      ]
    },
    "LatestFrameAvailableEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string"
        },
        "eventType": {
          "const": "latest_frame_available"
        },
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "artifactId": {
              "type": "string",
              "format": "uuid"
            },
            "artifactType": {
              "type": "string"
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "width": {
              "type": "integer",
              "minimum": 1
            },
            "height": {
              "type": "integer",
              "minimum": 1
            }
          },
          "required": [
            "artifactId",
            "url",
            "width",
            "height"
          ]
        }
      },
      "required": [
        "eventId",
        "eventType",
        "runId",
        "occurredAt",
        "payload"
      ]
    },
    "IssueSignalDetectedEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string"
        },
        "eventType": {
          "const": "issue_signal_detected"
        },
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "criterionId": {
              "type": "string"
            },
            "stage": {
              "enum": [
                "FIRST_VIEW",
                "VALUE",
                "CTA",
                "INPUT",
                "COMMIT"
              ]
            },
            "axis": {
              "type": "string"
            },
            "severity": {
              "type": "integer",
              "minimum": 0,
              "maximum": 3
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "evidenceRefs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "category": {
              "type": "string"
            },
            "source": {
              "type": "string",
              "enum": [
                "RULE_ENGINE",
                "RUNNER",
                "ANALYZER"
              ]
            }
          },
          "required": [
            "confidence"
          ]
        }
      },
      "required": [
        "eventId",
        "eventType",
        "runId",
        "occurredAt",
        "payload"
      ]
    },
    "AnalysisStartedEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string"
        },
        "eventType": {
          "const": "analysis_started"
        },
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "analysisJobId": {
              "type": "string",
              "format": "uuid"
            },
            "analysisType": {
              "type": "string"
            }
          },
          "required": [
            "analysisJobId"
          ]
        }
      },
      "required": [
        "eventId",
        "eventType",
        "runId",
        "occurredAt",
        "payload"
      ]
    },
    "AnalysisFinishedEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string"
        },
        "eventType": {
          "const": "analysis_finished"
        },
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "analysisJobId": {
              "type": "string",
              "format": "uuid"
            },
            "status": {
              "type": "string",
              "enum": [
                "COMPLETED",
                "FAILED"
              ]
            },
            "frictionScore": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "overallRisk": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high",
                "critical"
              ]
            },
            "topIssuesCount": {
              "type": "integer",
              "minimum": 0
            },
            "reportId": {
              "type": "string",
              "format": "uuid"
            }
          },
          "required": [
            "analysisJobId",
            "status"
          ]
        }
      },
      "required": [
        "eventId",
        "eventType",
        "runId",
        "occurredAt",
        "payload"
      ]
    },
    "RunFailedEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string"
        },
        "eventType": {
          "const": "run_failed"
        },
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "failureCode": {
              "type": "string"
            },
            "failureMessage": {
              "type": "string"
            },
            "resultCompleteness": {
              "type": "string",
              "enum": [
                "NONE",
                "PARTIAL",
                "FINAL"
              ]
            }
          },
          "required": [
            "failureCode",
            "failureMessage"
          ]
        }
      },
      "required": [
        "eventId",
        "eventType",
        "runId",
        "occurredAt",
        "payload"
      ]
    },
    "DiscoveryStatusChangedEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string"
        },
        "eventType": {
          "const": "discovery_status_changed"
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "discoveryId": {
              "type": "string",
              "format": "uuid"
            },
            "status": {
              "type": "string",
              "enum": [
                "CREATED",
                "QUEUED",
                "RUNNING",
                "COMPLETED",
                "FAILED",
                "CANCELED"
              ]
            },
            "failureCode": {
              "type": [
                "string",
                "null"
              ]
            },
            "failureMessage": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "discoveryId",
            "status"
          ]
        }
      },
      "required": [
        "eventId",
        "eventType",
        "occurredAt",
        "payload"
      ]
    },
    "DiscoveryCheckpointCreatedEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string"
        },
        "eventType": {
          "const": "discovery_checkpoint_created"
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "discoveryId": {
              "type": "string",
              "format": "uuid"
            },
            "checkpointId": {
              "type": "string"
            },
            "checkpointKey": {
              "type": "string"
            },
            "stage": {
              "enum": [
                "FIRST_VIEW",
                "VALUE",
                "CTA",
                "INPUT",
                "COMMIT"
              ]
            },
            "observationCount": {
              "type": "integer",
              "minimum": 0
            },
            "artifactRefs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "latestFrameUrl": {
              "type": "string",
              "format": "uri"
            }
          },
          "required": [
            "discoveryId",
            "checkpointId"
          ]
        }
      },
      "required": [
        "eventId",
        "eventType",
        "occurredAt",
        "payload"
      ]
    },
    "ScenarioRecommendationsReadyEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string"
        },
        "eventType": {
          "const": "scenario_recommendations_ready"
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "discoveryId": {
              "type": "string",
              "format": "uuid"
            },
            "recommendations": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "scenarioType": {
                    "type": "string",
                    "enum": [
                      "LANDING_CTA",
                      "SIGNUP_LEAD_FORM",
                      "PRICING",
                      "PURCHASE_CHECKOUT",
                      "CONTACT",
                      "CONTENT_ONLY",
                      "CUSTOM_GUIDED"
                    ]
                  },
                  "recommendationLevel": {
                    "type": "string",
                    "enum": [
                      "HIGH",
                      "MEDIUM",
                      "LOW",
                      "NOT_AVAILABLE"
                    ]
                  },
                  "confidence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "reason": {
                    "type": "string"
                  },
                  "evidenceRefs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "suggestedStartUrl": {
                    "type": "string",
                    "format": "uri"
                  },
                  "suggestedTarget": {
                    "type": "object",
                    "additionalProperties": true
                  }
                },
                "required": [
                  "scenarioType",
                  "recommendationLevel",
                  "confidence"
                ]
              }
            }
          },
          "required": [
            "discoveryId",
            "recommendations"
          ]
        }
      },
      "required": [
        "eventId",
        "eventType",
        "occurredAt",
        "payload"
      ]
    }
  }
}
