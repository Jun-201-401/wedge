{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wedge.example.com/contracts/mcp/tools.schema.json",
  "title": "Wedge MCP Tool Contracts",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Tool"
      }
    }
  },
  "required": [
    "tools"
  ],
  "$defs": {
    "Tool": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "discover_site",
            "create_run",
            "create_run_from_discovery",
            "start_run",
            "stop_run",
            "get_discovery_result",
            "get_run_status",
            "get_run_summary",
            "list_run_events",
            "get_latest_snapshot",
            "get_step_evidence",
            "get_evidence_packet",
            "analyze_run",
            "generate_nudges",
            "export_report",
            "get_report",
            "list_reports"
          ]
        },
        "category": {
          "type": "string",
          "enum": [
            "read",
            "execute",
            "export"
          ]
        },
        "requiredScope": {
          "type": "string",
          "enum": [
            "wedge.read",
            "wedge.execute",
            "wedge.export"
          ]
        },
        "approvalPolicy": {
          "type": "string",
          "enum": [
            "never",
            "on_failure",
            "always"
          ]
        },
        "inputSchema": {
          "type": "object"
        },
        "outputSchema": {
          "type": "object"
        }
      },
      "required": [
        "name",
        "category",
        "requiredScope",
        "approvalPolicy",
        "inputSchema",
        "outputSchema"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "name": {
                "enum": [
                  "get_discovery_result",
                  "get_run_status",
                  "get_run_summary",
                  "list_run_events",
                  "get_latest_snapshot",
                  "get_step_evidence",
                  "get_evidence_packet",
                  "get_report",
                  "list_reports"
                ]
              }
            },
            "required": [
              "name"
            ]
          },
          "then": {
            "properties": {
              "category": {
                "const": "read"
              },
              "requiredScope": {
                "const": "wedge.read"
              },
              "approvalPolicy": {
                "enum": [
                  "never",
                  "on_failure"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "name": {
                "enum": [
                  "discover_site",
                  "create_run_from_discovery",
                  "create_run",
                  "start_run",
                  "stop_run",
                  "analyze_run",
                  "generate_nudges"
                ]
              }
            },
            "required": [
              "name"
            ]
          },
          "then": {
            "properties": {
              "category": {
                "const": "execute"
              },
              "requiredScope": {
                "const": "wedge.execute"
              },
              "approvalPolicy": {
                "enum": [
                  "on_failure",
                  "always"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "name": {
                "enum": [
                  "export_report"
                ]
              }
            },
            "required": [
              "name"
            ]
          },
          "then": {
            "properties": {
              "category": {
                "const": "export"
              },
              "requiredScope": {
                "const": "wedge.export"
              },
              "approvalPolicy": {
                "enum": [
                  "on_failure",
                  "always"
                ]
              }
            }
          }
        }
      ]
    }
  }
}
