{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wedge.example.com/contracts/mq/messages.schema.json",
  "title": "Wedge MQ Message Envelope",
  "oneOf": [
    {
      "$ref": "#/$defs/RunExecuteMessage"
    },
    {
      "$ref": "#/$defs/AgentExecuteMessage"
    },
    {
      "$ref": "#/$defs/AnalysisRequestMessage"
    },
    {
      "$ref": "#/$defs/ReportExportRequestMessage"
    },
    {
      "$ref": "#/$defs/DiscoveryExecuteMessage"
    },
    {
      "$ref": "#/$defs/DiscoveryEvaluateMessage"
    },
    {
      "$ref": "#/$defs/ScenarioAuthoringExecuteMessage"
    }
  ],
  "$defs": {
    "RunExecutePayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "projectId": {
          "type": "string",
          "format": "uuid"
        },
        "triggerSource": {
          "type": "string",
          "enum": [
            "WEB",
            "MCP",
            "INTERNAL_AGENT",
            "API"
          ]
        },
        "startUrl": {
          "type": "string",
          "format": "uri"
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "devicePreset": {
          "type": "string",
          "enum": [
            "desktop",
            "tablet",
            "mobile"
          ]
        },
        "scenarioTemplateVersionId": {
          "type": "string",
          "format": "uuid"
        },
        "scenarioOverrides": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "preferredCtaText": {
              "type": "string"
            },
            "inputValues": {
              "type": "object",
              "additionalProperties": {
                "type": [
                  "string",
                  "number",
                  "boolean",
                  "null"
                ]
              }
            }
          }
        },
        "scenarioPlan": {
          "type": "object",
          "additionalProperties": true
        },
        "artifactPolicy": {
          "type": "object",
          "additionalProperties": true
        },
        "sourceDiscoveryId": {
          "type": "string",
          "format": "uuid"
        },
        "scenarioFitRequirements": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requiredFlowType": {
              "type": "string",
              "enum": [
                "LANDING_CTA",
                "SIGNUP_LEAD_FORM",
                "PRICING",
                "PURCHASE_CHECKOUT",
                "CONTACT",
                "CONTENT_ONLY"
              ]
            },
            "requiredEntrypointTypes": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "cta",
                  "form",
                  "pricing",
                  "checkout",
                  "cart",
                  "signup",
                  "contact",
                  "content"
                ]
              }
            },
            "fallbackAllowed": {
              "type": "boolean"
            }
          }
        }
      },
      "required": [
        "runId",
        "projectId",
        "startUrl",
        "goal",
        "devicePreset",
        "scenarioTemplateVersionId",
        "scenarioPlan"
      ]
    },
    "AnalysisRequestPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "analysisJobId": {
          "type": "string",
          "format": "uuid"
        },
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "analysisType": {
          "type": "string",
          "enum": [
            "PRIMARY",
            "REPROCESS",
            "COMPARE"
          ]
        },
        "forceRebuildEvidenceBundle": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        },
        "ruleRegistryId": {
          "type": "string"
        },
        "evidencePacketId": {
          "type": "string",
          "format": "uuid"
        },
        "evidencePacket": {
          "$ref": "../schemas/evidence-packet.schema.json",
          "description": "Deprecated inline EvidencePacket payload. MVP Analyzer MQ consumers expect evidencePacketId and fetch the packet from Spring."
        }
      },
      "required": [
        "analysisJobId",
        "runId",
        "analysisType",
        "forceRebuildEvidenceBundle",
        "evidencePacketId"
      ]
    },
    "ReportExportRequestPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reportId": {
          "type": "string",
          "format": "uuid"
        },
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "analysisJobId": {
          "type": "string",
          "format": "uuid"
        },
        "format": {
          "type": "string",
          "enum": [
            "PDF",
            "MARKDOWN",
            "HTML",
            "JSON"
          ]
        }
      },
      "required": [
        "reportId",
        "runId",
        "analysisJobId",
        "format"
      ]
    },
    "RunExecuteMessage": {
      "title": "RunExecuteMessage",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "messageId": {
          "type": "string",
          "format": "uuid"
        },
        "messageType": {
          "const": "run.execute.request"
        },
        "schemaVersion": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string",
          "format": "uuid"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "$ref": "#/$defs/RunExecutePayload"
        }
      },
      "required": [
        "messageId",
        "messageType",
        "schemaVersion",
        "createdAt",
        "producer",
        "payload"
      ]
    },
    "AgentExecuteMessage": {
      "title": "AgentExecuteMessage",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "messageId": {
          "type": "string",
          "format": "uuid"
        },
        "messageType": {
          "const": "agent.execute.request"
        },
        "schemaVersion": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string",
          "format": "uuid"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "$ref": "#/$defs/AgentExecutePayload"
        }
      },
      "required": [
        "messageId",
        "messageType",
        "schemaVersion",
        "createdAt",
        "producer",
        "payload"
      ]
    },
    "AnalysisRequestMessage": {
      "title": "AnalysisRequestMessage",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "messageId": {
          "type": "string",
          "format": "uuid"
        },
        "messageType": {
          "const": "analysis.request"
        },
        "schemaVersion": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string",
          "format": "uuid"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "$ref": "#/$defs/AnalysisRequestPayload"
        }
      },
      "required": [
        "messageId",
        "messageType",
        "schemaVersion",
        "createdAt",
        "producer",
        "payload"
      ]
    },
    "ReportExportRequestMessage": {
      "title": "ReportExportRequestMessage",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "messageId": {
          "type": "string",
          "format": "uuid"
        },
        "messageType": {
          "const": "report.export.request"
        },
        "schemaVersion": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string",
          "format": "uuid"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "$ref": "#/$defs/ReportExportRequestPayload"
        }
      },
      "required": [
        "messageId",
        "messageType",
        "schemaVersion",
        "createdAt",
        "producer",
        "payload"
      ]
    },
    "DiscoveryExecutePayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "discoveryId": {
          "type": "string",
          "format": "uuid"
        },
        "projectId": {
          "type": "string",
          "format": "uuid"
        },
        "triggerSource": {
          "type": "string",
          "enum": [
            "WEB",
            "MCP",
            "INTERNAL_AGENT",
            "API"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "devicePreset": {
          "type": "string",
          "enum": [
            "desktop",
            "tablet",
            "mobile"
          ]
        },
        "viewport": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "width": {
              "type": "integer",
              "minimum": 1
            },
            "height": {
              "type": "integer",
              "minimum": 1
            }
          },
          "required": [
            "width",
            "height"
          ]
        },
        "maxDurationMs": {
          "type": "integer",
          "minimum": 1000
        },
        "maxScrollCount": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "discoveryId",
        "projectId",
        "url",
        "devicePreset",
        "viewport",
        "maxDurationMs",
        "maxScrollCount"
      ]
    },
    "DiscoveryEvaluatePayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "discoveryId": {
          "type": "string",
          "format": "uuid"
        },
        "evidencePacketRef": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "discoveryId",
        "evidencePacketRef"
      ]
    },
    "DiscoveryExecuteMessage": {
      "title": "DiscoveryExecuteMessage",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "messageId": {
          "type": "string",
          "format": "uuid"
        },
        "messageType": {
          "const": "discovery.execute.request"
        },
        "schemaVersion": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string",
          "format": "uuid"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "$ref": "#/$defs/DiscoveryExecutePayload"
        }
      },
      "required": [
        "messageId",
        "messageType",
        "schemaVersion",
        "createdAt",
        "producer",
        "payload"
      ]
    },
    "DiscoveryEvaluateMessage": {
      "title": "DiscoveryEvaluateMessage",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "messageId": {
          "type": "string",
          "format": "uuid"
        },
        "messageType": {
          "const": "discovery.evaluate.request"
        },
        "schemaVersion": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string",
          "format": "uuid"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "$ref": "#/$defs/DiscoveryEvaluatePayload"
        }
      },
      "required": [
        "messageId",
        "messageType",
        "schemaVersion",
        "createdAt",
        "producer",
        "payload"
      ]
    },
    "AgentExecutePayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agentTask": {
          "$ref": "#/$defs/AgentTask"
        }
      },
      "required": [
        "agentTask"
      ]
    },
    "AgentTask": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "0.1"
        },
        "task_id": {
          "type": "string",
          "format": "uuid"
        },
        "attempt_id": {
          "type": "string",
          "format": "uuid"
        },
        "attempt_index": {
          "type": "integer",
          "minimum": 1
        },
        "idempotency_key": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "format": "uuid"
        },
        "project_id": {
          "type": "string",
          "format": "uuid"
        },
        "goal_type": {
          "type": "string",
          "enum": [
            "CHECKOUT_ENTRY_VERIFICATION"
          ]
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "start_url": {
          "type": "string",
          "format": "uri"
        },
        "environment": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "device": {
              "type": "string",
              "enum": [
                "desktop",
                "mobile",
                "tablet"
              ]
            },
            "viewport": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "width": {
                  "type": "integer",
                  "minimum": 320
                },
                "height": {
                  "type": "integer",
                  "minimum": 480
                }
              },
              "required": [
                "width",
                "height"
              ]
            },
            "locale": {
              "type": "string",
              "minLength": 1
            },
            "timezone": {
              "type": "string",
              "minLength": 1
            },
            "geolocation": {
              "type": [
                "object",
                "null"
              ],
              "additionalProperties": true
            },
            "permissions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "auth_state": {
              "type": "string",
              "enum": [
                "anonymous",
                "test_account",
                "stored_state"
              ]
            }
          },
          "required": [
            "device",
            "viewport",
            "locale",
            "timezone",
            "auth_state"
          ]
        },
        "budget": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_steps": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "max_duration_ms": {
              "type": "integer",
              "minimum": 1000,
              "maximum": 600000
            },
            "max_recovery_attempts": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10
            },
            "max_same_page_attempts": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10
            },
            "max_external_redirects": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10
            }
          },
          "required": [
            "max_steps",
            "max_duration_ms"
          ]
        },
        "observation_budget": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_candidates": {
              "type": "integer",
              "minimum": 1,
              "maximum": 500
            },
            "max_visible_text_chars": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100000
            },
            "max_nearby_text_chars_per_candidate": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5000
            },
            "max_dom_snapshot_bytes": {
              "type": "integer",
              "minimum": 0
            },
            "max_ax_tree_bytes": {
              "type": "integer",
              "minimum": 0
            },
            "max_artifacts_per_run": {
              "type": "integer",
              "minimum": 0
            },
            "max_artifact_bytes_per_run": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "allowed_navigation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allow_external_navigation": {
              "type": "boolean"
            },
            "allowed_origins": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uri"
              }
            },
            "allowed_checkout_redirect_origins": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uri"
              }
            }
          },
          "required": [
            "allow_external_navigation"
          ]
        },
        "product_selection_policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "PROVIDED_OR_OBVIOUS_ONLY"
              ]
            },
            "provided_product_url": {
              "type": [
                "string",
                "null"
              ],
              "format": "uri"
            },
            "required_option_strategy": {
              "type": "string",
              "enum": [
                "FIRST_AVAILABLE"
              ]
            },
            "allow_quantity_change": {
              "type": "boolean"
            },
            "max_add_to_cart_attempts": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10
            }
          },
          "required": [
            "mode"
          ]
        },
        "risk_policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allow_checkout_navigation": {
              "type": "boolean"
            },
            "allow_cart_mutation": {
              "type": "boolean"
            },
            "allow_shipping_form_entry": {
              "type": "boolean"
            },
            "allow_payment_info_entry": {
              "type": "boolean"
            },
            "allow_final_payment_submit": {
              "type": "boolean"
            },
            "allow_final_order_commit": {
              "type": "boolean"
            },
            "allow_destructive_action": {
              "type": "boolean"
            },
            "allow_external_message_send": {
              "type": "boolean"
            }
          },
          "required": [
            "allow_checkout_navigation",
            "allow_cart_mutation",
            "allow_shipping_form_entry",
            "allow_payment_info_entry",
            "allow_final_payment_submit",
            "allow_final_order_commit",
            "allow_destructive_action",
            "allow_external_message_send"
          ]
        },
        "test_data": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "email": {
              "type": [
                "string",
                "null"
              ]
            },
            "name": {
              "type": [
                "string",
                "null"
              ]
            },
            "phone": {
              "type": [
                "string",
                "null"
              ]
            },
            "shipping_address": {
              "type": [
                "object",
                "null"
              ],
              "additionalProperties": true
            },
            "postal_code": {
              "type": [
                "string",
                "null"
              ]
            },
            "country": {
              "type": [
                "string",
                "null"
              ]
            },
            "coupon_code": {
              "type": [
                "string",
                "null"
              ]
            },
            "sandbox_payment": {
              "type": [
                "object",
                "null"
              ],
              "additionalProperties": true
            }
          }
        },
        "artifact_policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "capture_screenshots": {
              "type": "boolean"
            },
            "screenshot_mode": {
              "type": "string",
              "enum": [
                "auto",
                "viewport",
                "full_page",
                "viewport_stitched"
              ]
            },
            "capture_dom_snapshots": {
              "type": "boolean"
            },
            "capture_ax_tree": {
              "type": "boolean"
            },
            "capture_trace": {
              "type": "boolean"
            },
            "capture_har": {
              "type": "boolean"
            },
            "capture_performance": {
              "type": "boolean"
            }
          }
        },
        "replay_hints": {
          "$ref": "#/$defs/AgentReplayHints"
        }
      },
      "required": [
        "schema_version",
        "task_id",
        "attempt_id",
        "attempt_index",
        "run_id",
        "project_id",
        "goal_type",
        "start_url",
        "environment",
        "budget",
        "allowed_navigation",
        "risk_policy"
      ]
    },
    "AgentReplayHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_trace_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "source_plan_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AgentReplayHintStep"
          }
        }
      },
      "required": [
        "steps"
      ]
    },
    "AgentReplayHintStep": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "step_id": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "type": "string",
          "enum": [
            "FIRST_VIEW",
            "VALUE",
            "CTA",
            "INPUT",
            "COMMIT"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "goto",
                "click",
                "fill",
                "select",
                "scroll",
                "hover",
                "wait_for",
                "checkpoint",
                "stop_when"
              ]
            }
          },
          "required": [
            "type"
          ]
        },
        "settle_strategy": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "network_idle",
                "locator_visible",
                "response",
                "url_change",
                "spinner_hidden",
                "item_count_change",
                "fixed_short",
                "none"
              ]
            },
            "timeout_ms": {
              "type": "number",
              "minimum": 0
            }
          },
          "required": [
            "type",
            "timeout_ms"
          ]
        },
        "target_key": {
          "type": [
            "string",
            "null"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "action"
      ]
    },
    "ScenarioAuthoringExecutePayload": {
      "type": "object",
      "additionalProperties": false,
