{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wedge.example.com/contracts/mq/messages.schema.json",
  "title": "Wedge RabbitMQ Message Envelope",
  "oneOf": [
    {
      "$ref": "#/$defs/RunExecuteMessage"
    },
    {
      "$ref": "#/$defs/AnalysisRequestMessage"
    },
    {
      "$ref": "#/$defs/ReportExportRequestMessage"
    }
  ],
  "$defs": {
    "RunExecutePayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "projectId": {
          "type": "string",
          "format": "uuid"
        },
        "triggerSource": {
          "type": "string",
          "enum": [
            "WEB",
            "MCP",
            "INTERNAL_AGENT",
            "API"
          ]
        },
        "startUrl": {
          "type": "string",
          "format": "uri"
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "devicePreset": {
          "type": "string",
          "enum": [
            "desktop",
            "tablet",
            "mobile"
          ]
        },
        "scenarioTemplateVersionId": {
          "type": "string",
          "format": "uuid"
        },
        "scenarioOverrides": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "preferredCtaText": {
              "type": "string"
            },
            "inputValues": {
              "type": "object",
              "additionalProperties": {
                "type": [
                  "string",
                  "number",
                  "boolean",
                  "null"
                ]
              }
            }
          }
        },
        "scenarioPlan": {
          "type": "object",
          "additionalProperties": true
        },
        "artifactPolicy": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": [
        "runId",
        "projectId",
        "startUrl",
        "goal",
        "devicePreset",
        "scenarioTemplateVersionId",
        "scenarioPlan"
      ]
    },
    "AnalysisRequestPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "analysisJobId": {
          "type": "string",
          "format": "uuid"
        },
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "analysisType": {
          "type": "string",
          "enum": [
            "PRIMARY",
            "REPROCESS",
            "COMPARE"
          ]
        },
        "forceRebuildEvidenceBundle": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        },
        "ruleRegistryId": {
          "type": "string"
        },
        "evidencePacketId": {
          "type": "string",
          "format": "uuid"
        }
      },
      "required": [
        "analysisJobId",
        "runId",
        "analysisType",
        "forceRebuildEvidenceBundle",
        "evidencePacketId"
      ]
    },
    "ReportExportRequestPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reportId": {
          "type": "string",
          "format": "uuid"
        },
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "analysisJobId": {
          "type": "string",
          "format": "uuid"
        },
        "format": {
          "type": "string",
          "enum": [
            "PDF",
            "MARKDOWN",
            "HTML",
            "JSON"
          ]
        }
      },
      "required": [
        "reportId",
        "runId",
        "analysisJobId",
        "format"
      ]
    },
    "RunExecuteMessage": {
      "title": "RunExecuteMessage",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "messageId": {
          "type": "string",
          "format": "uuid"
        },
        "messageType": {
          "const": "run.execute.request"
        },
        "schemaVersion": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string",
          "format": "uuid"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "$ref": "#/$defs/RunExecutePayload"
        }
      },
      "required": [
        "messageId",
        "messageType",
        "schemaVersion",
        "createdAt",
        "producer",
        "payload"
      ]
    },
    "AnalysisRequestMessage": {
      "title": "AnalysisRequestMessage",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "messageId": {
          "type": "string",
          "format": "uuid"
        },
        "messageType": {
          "const": "analysis.request"
        },
        "schemaVersion": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string",
          "format": "uuid"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "$ref": "#/$defs/AnalysisRequestPayload"
        }
      },
      "required": [
        "messageId",
        "messageType",
        "schemaVersion",
        "createdAt",
        "producer",
        "payload"
      ]
    },
    "ReportExportRequestMessage": {
      "title": "ReportExportRequestMessage",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "messageId": {
          "type": "string",
          "format": "uuid"
        },
        "messageType": {
          "const": "report.export.request"
        },
        "schemaVersion": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string",
          "format": "uuid"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "$ref": "#/$defs/ReportExportRequestPayload"
        }
      },
      "required": [
        "messageId",
        "messageType",
        "schemaVersion",
        "createdAt",
        "producer",
        "payload"
      ]
    }
  }
}
