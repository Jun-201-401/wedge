{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wedge.example.com/contracts/mq/messages.schema.json",
  "title": "Wedge MQ Message Envelope",
  "oneOf": [
    {
      "$ref": "#/$defs/RunExecuteMessage"
    },
    {
      "$ref": "#/$defs/AnalysisRequestMessage"
    },
    {
      "$ref": "#/$defs/ReportExportRequestMessage"
    },
    {
      "$ref": "#/$defs/DiscoveryExecuteMessage"
    },
    {
      "$ref": "#/$defs/DiscoveryEvaluateMessage"
    }
  ],
  "$defs": {
    "RunExecutePayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "projectId": {
          "type": "string",
          "format": "uuid"
        },
        "triggerSource": {
          "type": "string",
          "enum": [
            "WEB",
            "MCP",
            "INTERNAL_AGENT",
            "API"
          ]
        },
        "startUrl": {
          "type": "string",
          "format": "uri"
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "devicePreset": {
          "type": "string",
          "enum": [
            "desktop",
            "tablet",
            "mobile"
          ]
        },
        "scenarioTemplateVersionId": {
          "type": "string",
          "format": "uuid"
        },
        "scenarioOverrides": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "preferredCtaText": {
              "type": "string"
            },
            "inputValues": {
              "type": "object",
              "additionalProperties": {
                "type": [
                  "string",
                  "number",
                  "boolean",
                  "null"
                ]
              }
            }
          }
        },
        "scenarioPlan": {
          "type": "object",
          "additionalProperties": true
        },
        "artifactPolicy": {
          "type": "object",
          "additionalProperties": true
        },
        "sourceDiscoveryId": {
          "type": "string",
          "format": "uuid"
        },
        "scenarioFitRequirements": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requiredFlowType": {
              "type": "string",
              "enum": [
                "LANDING_CTA",
                "SIGNUP_LEAD_FORM",
                "PRICING",
                "PURCHASE_CHECKOUT",
                "CONTACT",
                "CONTENT_ONLY"
              ]
            },
            "requiredEntrypointTypes": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "cta",
                  "form",
                  "pricing",
                  "checkout",
                  "cart",
                  "signup",
                  "contact",
                  "content"
                ]
              }
            },
            "fallbackAllowed": {
              "type": "boolean"
            }
          }
        },
        "executionMode": {
          "type": "string",
          "enum": [
            "agent",
            "scripted"
          ],
          "default": "agent"
        },
        "agentConfig": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxTurns": {
              "type": "integer",
              "minimum": 1,
              "maximum": 20,
              "default": 8
            },
            "maxScrolls": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10,
              "default": 3
            },
            "autonomyLevel": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high"
              ],
              "default": "medium"
            },
            "allowReplayHints": {
              "type": "boolean",
              "default": true
            },
            "captureEveryTurn": {
              "type": "boolean",
              "default": true
            }
          }
        }
      },
      "required": [
        "runId",
        "projectId",
        "startUrl",
        "goal",
        "devicePreset"
      ]
    },
    "AnalysisRequestPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "analysisJobId": {
          "type": "string",
          "format": "uuid"
        },
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "analysisType": {
          "type": "string",
          "enum": [
            "PRIMARY",
            "REPROCESS",
            "COMPARE"
          ]
        },
        "forceRebuildEvidenceBundle": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        },
        "ruleRegistryId": {
          "type": "string"
        },
        "evidencePacketId": {
          "type": "string",
          "format": "uuid"
        },
        "evidencePacket": {
          "$ref": "../schemas/evidence-packet.schema.json",
          "description": "Deprecated inline EvidencePacket payload. MVP Analyzer MQ consumers expect evidencePacketId and fetch the packet from Spring."
        }
      },
      "required": [
        "analysisJobId",
        "runId",
        "analysisType",
        "forceRebuildEvidenceBundle",
        "evidencePacketId"
      ]
    },
    "ReportExportRequestPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reportId": {
          "type": "string",
          "format": "uuid"
        },
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "analysisJobId": {
          "type": "string",
          "format": "uuid"
        },
        "format": {
          "type": "string",
          "enum": [
            "PDF",
            "MARKDOWN",
            "HTML",
            "JSON"
          ]
        }
      },
      "required": [
        "reportId",
        "runId",
        "analysisJobId",
        "format"
      ]
    },
    "RunExecuteMessage": {
      "title": "RunExecuteMessage",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "messageId": {
          "type": "string",
          "format": "uuid"
        },
        "messageType": {
          "const": "run.execute.request"
        },
        "schemaVersion": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string",
          "format": "uuid"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "$ref": "#/$defs/RunExecutePayload"
        }
      },
      "required": [
        "messageId",
        "messageType",
        "schemaVersion",
        "createdAt",
        "producer",
        "payload"
      ]
    },
    "AnalysisRequestMessage": {
      "title": "AnalysisRequestMessage",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "messageId": {
          "type": "string",
          "format": "uuid"
        },
        "messageType": {
          "const": "analysis.request"
        },
        "schemaVersion": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string",
          "format": "uuid"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "$ref": "#/$defs/AnalysisRequestPayload"
        }
      },
      "required": [
        "messageId",
        "messageType",
        "schemaVersion",
        "createdAt",
        "producer",
        "payload"
      ]
    },
    "ReportExportRequestMessage": {
      "title": "ReportExportRequestMessage",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "messageId": {
          "type": "string",
          "format": "uuid"
        },
        "messageType": {
          "const": "report.export.request"
        },
        "schemaVersion": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string",
          "format": "uuid"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "$ref": "#/$defs/ReportExportRequestPayload"
        }
      },
      "required": [
        "messageId",
        "messageType",
        "schemaVersion",
        "createdAt",
        "producer",
        "payload"
      ]
    },
    "DiscoveryExecutePayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "discoveryId": {
          "type": "string",
          "format": "uuid"
        },
        "projectId": {
          "type": "string",
          "format": "uuid"
        },
        "triggerSource": {
          "type": "string",
          "enum": [
            "WEB",
            "MCP",
            "INTERNAL_AGENT",
            "API"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "devicePreset": {
          "type": "string",
          "enum": [
            "desktop",
            "tablet",
            "mobile"
          ]
        },
        "viewport": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "width": {
              "type": "integer",
              "minimum": 1
            },
            "height": {
              "type": "integer",
              "minimum": 1
            }
          },
          "required": [
            "width",
            "height"
          ]
        },
        "maxDurationMs": {
          "type": "integer",
          "minimum": 1000
        },
        "maxScrollCount": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "discoveryId",
        "projectId",
        "url",
        "devicePreset",
        "viewport",
        "maxDurationMs",
        "maxScrollCount"
      ]
    },
    "DiscoveryEvaluatePayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "discoveryId": {
          "type": "string",
          "format": "uuid"
        },
        "evidencePacketRef": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "discoveryId",
        "evidencePacketRef"
      ]
    },
    "DiscoveryExecuteMessage": {
      "title": "DiscoveryExecuteMessage",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "messageId": {
          "type": "string",
          "format": "uuid"
        },
        "messageType": {
          "const": "discovery.execute.request"
        },
        "schemaVersion": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string",
          "format": "uuid"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "$ref": "#/$defs/DiscoveryExecutePayload"
        }
      },
      "required": [
        "messageId",
        "messageType",
        "schemaVersion",
        "createdAt",
        "producer",
        "payload"
      ]
    },
    "DiscoveryEvaluateMessage": {
      "title": "DiscoveryEvaluateMessage",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "messageId": {
          "type": "string",
          "format": "uuid"
        },
        "messageType": {
          "const": "discovery.evaluate.request"
        },
        "schemaVersion": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string",
          "format": "uuid"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "$ref": "#/$defs/DiscoveryEvaluatePayload"
        }
      },
      "required": [
        "messageId",
        "messageType",
        "schemaVersion",
        "createdAt",
        "producer",
        "payload"
      ]
    }
  }
}
