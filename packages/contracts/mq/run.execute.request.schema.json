{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wedge.example.com/contracts/mq/run.execute.request.schema.json",
  "title": "Run Execute Request",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "messageId": { "type": "string", "format": "uuid" },
    "requestedAt": { "type": "string", "format": "date-time" },
    "correlationId": { "type": "string", "format": "uuid" },
    "idempotencyKey": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "format": "uuid" },
    "projectId": { "type": "string", "format": "uuid" },
    "triggerSource": { "type": "string", "enum": ["WEB", "MCP", "SYSTEM"] },
    "startUrl": { "type": "string", "format": "uri" },
    "goal": { "type": "string", "minLength": 1 },
    "devicePreset": { "type": "string", "enum": ["desktop", "tablet", "mobile"] },
    "scenarioTemplateVersionId": { "type": "string", "format": "uuid" },
    "scenarioOverrides": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "preferredCtaText": { "type": "string" },
        "inputValues": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null"]
          }
        }
      }
    }
  },
  "required": [
    "messageId",
    "requestedAt",
    "runId",
    "projectId",
    "startUrl",
    "goal",
    "devicePreset"
  ]
}
