            "issues": [
              {
                "issue_id": "issue_002",
                "criterion_id": "INPUT-ASYNC-001",
                "stage": "INPUT",
                "axis": "Clarity",
                "severity": 1,
                "confidence": 0.72,
                "priority_score": 1.44,
                "evidence_refs": [
                  "cp_002.obs_004"
                ],
                "summary": "이메일 입력 단계가 서버 validation response에 의존해 입력 완료감이 지연될 수 있습니다.",
                "recommendations": [
                  "validation 진행 중 로딩/성공 상태를 입력 필드 근처에 즉시 노출하기"
                ]
              },
              {
                "issue_id": "issue_003",
                "criterion_id": "VALUE-LIST-001",
                "stage": "VALUE",
                "axis": "Path",
                "severity": 1,
                "confidence": 0.74,
                "priority_score": 1.51,
                "evidence_refs": [
                  "cp_003.obs_006"
                ],
                "summary": "혜택 목록 확장 후 항목 수가 급격히 늘어나 사용자의 읽기 부담이 커질 수 있습니다.",
                "recommendations": [
                  "새로 추가되는 혜택 중 핵심 1~2개를 상단에 고정해 우선순위를 보여주기"
                ]
              },
              {
                "issue_id": "issue_004",
                "criterion_id": "INPUT-ASYNC-002",
                "stage": "INPUT",
                "axis": "Trust",
                "severity": 2,
                "confidence": 0.76,
                "priority_score": 1.88,
                "evidence_refs": [
                  "cp_004.obs_008"
                ],
                "summary": "입력 검증 response가 timeout되면 사용자가 다음 진행 가능 여부를 신뢰하기 어려울 수 있습니다.",
                "recommendations": [
                  "validation timeout 시 재시도 버튼과 fallback 안내 메시지를 노출하기"
                ]
              }
            ],
            "decision_map": [
              {
                "stage": "INPUT",
                "status": "warning",
                "issue_ids": [
                  "issue_002",
                  "issue_004"
                ]
              },
              {
                "stage": "VALUE",
                "status": "warning",
                "issue_ids": [
                  "issue_003"
                ]
              }
            ]
          },
          "completedAt": "2026-04-21T08:15:00.000Z"
        }
      ]
