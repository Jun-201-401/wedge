{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wedge.example.com/contracts/internal/analyzer-callback.schema.json",
  "title": "Analyzer Callback Payloads",
  "$defs": {
    "Completed": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "analysisJobId": {
          "type": "string",
          "format": "uuid"
        },
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "analyzerVersion": {
          "type": "string",
          "minLength": 1
        },
        "promptVersion": {
          "type": "string",
          "minLength": 1
        },
        "modelInfo": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "llm": {
              "type": "string"
            },
            "attentionModel": {
              "type": "string"
            },
            "ctrModel": {
              "type": "string"
            }
          }
        },
        "topFindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Finding"
          }
        },
        "nudges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Nudge"
          }
        },
        "completedAt": {
          "type": "string",
          "format": "date-time"
        },
        "judgeResult": {
          "$ref": "../schemas/judge-result.schema.json"
        }
      },
      "required": [
        "analysisJobId",
        "runId",
        "analyzerVersion",
        "promptVersion",
        "modelInfo",
        "topFindings",
        "nudges",
        "judgeResult",
        "completedAt"
      ],
      "examples": [
        {
