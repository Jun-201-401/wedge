          "runId": "run_001",
          "analyzerVersion": "analyzer-0.5.0",
          "promptVersion": "judge-prompts-2026-04-21",
          "modelInfo": {
            "llm": "gpt-5.4-mini",
            "attentionModel": "rule-engine-v1",
            "ctrModel": "ctr-baseline-v1"
          },
