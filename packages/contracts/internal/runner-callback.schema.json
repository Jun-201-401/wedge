{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wedge.example.com/contracts/internal/runner-callback.schema.json",
  "title": "Runner Callback Payloads",
  "$defs": {
    "Accepted": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workerId": { "type": "string", "minLength": 1 },
        "acceptedAt": { "type": "string", "format": "date-time" },
        "browserSessionId": { "type": "string", "minLength": 1 }
      },
      "required": ["workerId", "acceptedAt", "browserSessionId"]
    },
    "StepEventBatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "events": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/StepEvent" }
        }
      },
      "required": ["events"]
    },
    "StepEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": { "type": "string", "format": "uuid" },
        "stepOrder": { "type": "integer", "minimum": 1 },
        "stepId": { "type": "string", "format": "uuid" },
        "eventType": {
          "type": "string",
          "enum": [
            "STEP_STARTED",
            "ACTION_EXECUTED",
            "STEP_COMPLETED",
            "CONSOLE_ERROR",
            "NETWORK_ERROR",
            "ISSUE_SIGNAL_DETECTED"
          ]
        },
        "occurredAt": { "type": "string", "format": "date-time" },
        "payload": { "type": "object", "additionalProperties": true }
      },
      "required": ["eventId", "stepOrder", "stepId", "eventType", "occurredAt", "payload"]
    },
    "ArtifactBatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Artifact" }
        }
      },
      "required": ["artifacts"]
    },
    "Artifact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifactId": { "type": "string", "format": "uuid" },
        "stepId": { "type": "string", "format": "uuid" },
        "artifactType": { "type": "string", "enum": ["FRAME", "SCREENSHOT", "TRACE", "SNAPSHOT", "LOG"] },
        "bucket": { "type": "string", "minLength": 1 },
        "key": { "type": "string", "minLength": 1 },
        "mimeType": { "type": "string", "minLength": 1 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "sizeBytes": { "type": "integer", "minimum": 0 },
        "sha256": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": [
        "artifactId",
        "stepId",
        "artifactType",
        "bucket",
        "key",
        "mimeType",
        "sizeBytes",
        "sha256",
        "createdAt"
      ]
    },
    "Finished": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workerId": { "type": "string", "minLength": 1 },
        "executionFinishedAt": { "type": "string", "format": "date-time" },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "completedStepCount": { "type": "integer", "minimum": 0 },
            "failedStepCount": { "type": "integer", "minimum": 0 },
            "stopped": { "type": "boolean" }
          },
          "required": ["completedStepCount", "failedStepCount", "stopped"]
        }
      },
      "required": ["workerId", "executionFinishedAt", "summary"]
    },
    "Failed": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workerId": { "type": "string", "minLength": 1 },
        "failedAt": { "type": "string", "format": "date-time" },
        "failureCode": { "type": "string", "minLength": 1 },
        "failureMessage": { "type": "string", "minLength": 1 },
        "resultCompleteness": { "type": "string", "enum": ["NONE", "PARTIAL", "FINAL"] }
      },
      "required": ["workerId", "failedAt", "failureCode", "failureMessage", "resultCompleteness"]
    }
  }
}
