{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wedge.example.com/contracts/internal/runner-callback.schema.json",
  "title": "Runner Callback Payloads",
  "$defs": {
    "Accepted": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workerId": {
          "type": "string",
          "minLength": 1
        },
        "acceptedAt": {
          "type": "string",
          "format": "date-time"
        },
        "browserSessionId": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "workerId",
        "acceptedAt",
        "browserSessionId"
      ]
    },
    "StepEventBatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/StepEvent"
          }
        }
      },
      "required": [
        "events"
      ]
    },
    "StepEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string",
          "format": "uuid"
        },
        "stepOrder": {
          "type": "integer",
          "minimum": 1
        },
        "eventType": {
          "type": "string",
          "enum": [
            "STEP_STARTED",
            "ACTION_EXECUTED",
            "STEP_COMPLETED",
            "CONSOLE_ERROR",
            "NETWORK_ERROR",
            "ISSUE_SIGNAL_DETECTED"
          ]
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": true
        },
        "stepKey": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "eventId",
        "stepOrder",
        "stepKey",
        "eventType",
        "occurredAt",
        "payload"
      ]
    },
    "ArtifactBatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Artifact"
          }
        }
      },
      "required": [
        "artifacts"
      ]
    },
    "Artifact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifactId": {
          "type": "string",
          "format": "uuid"
        },
        "artifactType": {
          "type": "string",
          "enum": [
            "FRAME",
            "SCREENSHOT",
            "DOM_SNAPSHOT",
            "AX_TREE",
            "TRACE",
            "HAR",
            "CONSOLE_LOG",
            "REPORT_PDF",
            "REPORT_MARKDOWN",
            "REPORT_HTML",
            "REPORT_JSON",
            "OTHER"
          ]
        },
        "bucket": {
          "type": "string",
          "minLength": 1
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "mimeType": {
          "type": "string",
          "minLength": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "stepKey": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "artifactId",
        "stepKey",
        "artifactType",
        "bucket",
        "key",
        "mimeType",
        "sizeBytes",
        "sha256",
        "createdAt"
      ]
    },
    "Finished": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workerId": {
          "type": "string",
          "minLength": 1
        },
        "executionFinishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "completedStepCount": {
              "type": "integer",
              "minimum": 0
            },
            "failedStepCount": {
              "type": "integer",
              "minimum": 0
            },
            "stopped": {
              "type": "boolean"
            }
          },
          "required": [
            "completedStepCount",
            "failedStepCount",
            "stopped"
          ]
        }
      },
      "required": [
        "workerId",
        "executionFinishedAt",
        "summary"
      ]
    },
    "Failed": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workerId": {
          "type": "string",
          "minLength": 1
        },
        "failedAt": {
          "type": "string",
          "format": "date-time"
        },
        "failureCode": {
          "type": "string",
          "minLength": 1
        },
        "failureMessage": {
          "type": "string",
          "minLength": 1
        },
        "resultCompleteness": {
          "type": "string",
          "enum": [
            "NONE",
            "PARTIAL",
            "FINAL"
          ]
        }
      },
      "required": [
        "workerId",
        "failedAt",
        "failureCode",
        "failureMessage",
        "resultCompleteness"
      ]
    },
    "Checkpoint": {
      "type": "object",
      "required": [
        "checkpointId",
        "stepKey",
        "stage",
        "trigger",
        "settle",
        "state",
        "observations",
        "deltas",
        "artifactRefs"
      ],
      "properties": {
        "checkpointId": {
          "type": "string"
        },
        "stage": {
          "enum": [
            "FIRST_VIEW",
            "VALUE",
            "CTA",
            "INPUT",
            "COMMIT"
          ]
        },
        "trigger": {
          "type": "object",
          "additionalProperties": true
        },
        "settle": {
          "type": "object",
          "required": [
            "strategy",
            "durationMs",
            "status"
          ],
          "properties": {
            "strategy": {
              "type": "string"
            },
            "durationMs": {
              "type": "integer",
              "minimum": 0
            },
            "status": {
              "enum": [
                "settled",
                "timeout",
                "failed"
              ]
            }
          },
          "additionalProperties": true
        },
        "state": {
          "type": "object",
          "additionalProperties": true
        },
        "observations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "deltas": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "artifactRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stepKey": {
          "type": "string",
          "minLength": 1
        }
      },
      "title": "Checkpoint"
    },
    "RunnerCheckpointsRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "checkpoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Checkpoint"
          }
        }
      },
      "required": [
        "checkpoints"
      ]
    },
    "DiscoveryAccepted": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string",
          "minLength": 1
        },
        "workerId": {
          "type": "string",
          "minLength": 1
        },
        "acceptedAt": {
          "type": "string",
          "format": "date-time"
        },
        "browserSessionId": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "eventId",
        "workerId",
        "acceptedAt",
        "browserSessionId"
      ]
    },
    "DiscoveryCheckpointRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string",
          "minLength": 1
        },
        "workerId": {
          "type": "string",
          "minLength": 1
        },
        "checkpoint": {
          "$ref": "#/$defs/Checkpoint"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Artifact"
          }
        },
        "observations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "required": [
        "eventId",
        "workerId",
        "checkpoint",
        "artifacts",
        "observations"
      ]
    },
    "DiscoverySummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "detectedFlowTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "LANDING_CTA",
              "SIGNUP_LEAD_FORM",
              "PRICING",
              "PURCHASE_CHECKOUT",
              "CONTACT",
              "CONTENT_ONLY"
            ]
          }
        },
        "missingFlowTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "LANDING_CTA",
              "SIGNUP_LEAD_FORM",
              "PRICING",
              "PURCHASE_CHECKOUT",
              "CONTACT",
              "CONTENT_ONLY"
            ]
          }
        },
        "primaryCtaCount": {
          "type": "integer",
          "minimum": 0
        },
        "formCandidateCount": {
          "type": "integer",
          "minimum": 0
        },
        "pricingEntrypointCount": {
          "type": "integer",
          "minimum": 0
        },
        "checkoutEntrypointCount": {
          "type": "integer",
          "minimum": 0
        },
        "scenarioRecommendations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "scenarioType": {
                "type": "string",
                "enum": [
                  "LANDING_CTA",
                  "SIGNUP_LEAD_FORM",
                  "PRICING",
                  "PURCHASE_CHECKOUT",
                  "CONTACT",
                  "CONTENT_ONLY",
                  "CUSTOM_GUIDED"
                ]
              },
              "recommendationLevel": {
                "type": "string",
                "enum": [
                  "HIGH",
                  "MEDIUM",
                  "LOW",
                  "NOT_AVAILABLE"
                ]
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "reason": {
                "type": "string"
              },
              "evidenceRefs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "suggestedStartUrl": {
                "type": "string",
                "format": "uri"
              },
              "suggestedTarget": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "required": [
              "scenarioType",
              "recommendationLevel",
              "confidence",
              "reason",
              "evidenceRefs"
            ]
          }
        }
      },
      "required": [
        "detectedFlowTypes",
        "missingFlowTypes",
        "scenarioRecommendations"
      ]
    },
    "DiscoveryFinished": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string",
          "minLength": 1
        },
        "workerId": {
          "type": "string",
          "minLength": 1
        },
        "finishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "finalUrl": {
          "type": "string",
          "format": "uri"
        },
        "summary": {
          "$ref": "#/$defs/DiscoverySummary"
        }
      },
      "required": [
        "eventId",
        "workerId",
        "finishedAt",
        "finalUrl",
        "summary"
      ]
    },
    "DiscoveryFailed": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string",
          "minLength": 1
        },
        "workerId": {
          "type": "string",
          "minLength": 1
        },
        "failedAt": {
          "type": "string",
          "format": "date-time"
        },
        "failureCode": {
          "type": "string",
          "minLength": 1
        },
        "failureMessage": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "eventId",
        "workerId",
        "failedAt",
        "failureCode",
        "failureMessage"
      ]
    }
  }
}
