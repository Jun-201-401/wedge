{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wedge.example.com/contracts/internal/runner-callback.schema.json",
  "title": "Runner Callback Payloads",
  "$defs": {
    "Accepted": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workerId": {
          "type": "string",
          "minLength": 1
        },
        "acceptedAt": {
          "type": "string",
          "format": "date-time"
        },
        "browserSessionId": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "workerId",
        "acceptedAt",
        "browserSessionId"
      ]
    },
    "StepEventBatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/StepEvent"
          }
        }
      },
      "required": [
        "events"
      ]
    },
    "StepEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string",
          "format": "uuid"
        },
        "stepOrder": {
          "type": "integer",
          "minimum": 1
        },
        "eventType": {
          "type": "string",
          "enum": [
            "STEP_STARTED",
            "ACTION_EXECUTED",
            "STEP_COMPLETED",
            "STEP_BLOCKED",
            "STEP_FAILED",
            "CONSOLE_ERROR",
            "NETWORK_ERROR",
            "ISSUE_SIGNAL_DETECTED"
          ]
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": true
        },
        "stepKey": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "eventId",
        "stepOrder",
        "stepKey",
        "eventType",
        "occurredAt",
        "payload"
      ]
    },
    "ArtifactBatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Artifact"
          }
        }
      },
      "required": [
        "artifacts"
      ]
    },
    "Artifact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifactId": {
          "type": "string",
          "format": "uuid"
        },
        "artifactType": {
          "type": "string",
          "enum": [
            "FRAME",
            "SCREENSHOT",
            "DOM_SNAPSHOT",
            "AX_TREE",
            "TRACE",
            "HAR",
            "CONSOLE_LOG",
            "REPORT_PDF",
            "REPORT_MARKDOWN",
            "REPORT_HTML",
            "REPORT_JSON",
            "OTHER"
          ]
        },
        "bucket": {
          "type": "string",
          "minLength": 1
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "mimeType": {
          "type": "string",
          "minLength": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "stepKey": {
          "description": "Scenario step key for step-scoped artifacts. Reserved agent run-scoped keys such as agent_trace and agent_scenario_plan_export are persisted without resolving a ScenarioPlan step.",
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "artifactId",
        "stepKey",
        "artifactType",
        "bucket",
        "key",
        "mimeType",
        "sizeBytes",
        "sha256",
        "createdAt"
      ]
    },
    "Finished": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workerId": {
          "type": "string",
          "minLength": 1
        },
        "executionFinishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "completedStepCount": {
              "type": "integer",
              "minimum": 0
            },
            "failedStepCount": {
              "type": "integer",
              "minimum": 0
            },
            "stopped": {
              "type": "boolean",
              "description": "True when runner execution stopped at a planned safety stop condition or after an explicit stop request. API status remains COMPLETED for planned scenario stops and becomes STOPPED only when the run was already STOP_REQUESTED."
            },
            "collectorStatus": {
              "$ref": "#/$defs/CollectorStatusSummary"
            }
          },
          "required": [
            "completedStepCount",
            "failedStepCount",
            "stopped"
          ]
        }
      },
      "required": [
        "workerId",
        "executionFinishedAt",
        "summary"
      ]
    },
    "Failed": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workerId": {
          "type": "string",
          "minLength": 1
        },
        "failedAt": {
          "type": "string",
          "format": "date-time"
        },
        "failureCode": {
          "type": "string",
          "minLength": 1
        },
        "failureMessage": {
          "type": "string",
          "minLength": 1
        },
        "resultCompleteness": {
          "type": "string",
          "enum": [
            "NONE",
            "PARTIAL",
            "FINAL"
          ]
        },
        "summary": {
          "$ref": "#/$defs/Finished/properties/summary"
        },
        "failedStepKey": {
          "type": "string",
          "minLength": 1
        },
        "failedStepOrder": {
          "type": "integer",
          "minimum": 1
        },
        "lastCheckpointId": {
          "type": "string",
          "minLength": 1
        },
        "failureArtifactRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "workerId",
        "failedAt",
        "failureCode",
        "failureMessage",
        "resultCompleteness"
      ]
    },
    "ControlState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runId": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "CREATED",
            "QUEUED",
            "STARTING",
            "RUNNING",
            "STOP_REQUESTED",
            "STOPPED",
            "COMPLETED",
            "FAILED"
          ]
        },
        "stopRequested": {
          "type": "boolean"
        },
        "resultCompleteness": {
          "type": "string",
          "enum": [
            "NONE",
            "PARTIAL",
            "FINAL"
          ]
        }
      },
      "required": [
        "runId",
        "status",
        "stopRequested"
      ]
    },
    "Checkpoint": {
      "type": "object",
      "required": [
        "checkpointId",
        "stepKey",
        "stage",
        "trigger",
        "settle",
        "state",
        "observations",
        "deltas",
        "artifactRefs"
      ],
      "properties": {
        "checkpointId": {
          "type": "string"
        },
        "stage": {
          "$ref": "#/$defs/DecisionStage",
          "description": "Runner callback stage emitted from ScenarioStep.stage. EvidencePacket may normalize this field to primaryStage."
        },
        "trigger": {
          "type": "object",
          "additionalProperties": true
        },
        "settle": {
          "type": "object",
          "required": [
            "strategy",
            "durationMs",
            "status"
          ],
          "properties": {
            "strategy": {
              "type": "string"
            },
            "durationMs": {
              "type": "integer",
              "minimum": 0
            },
            "status": {
              "enum": [
                "settled",
                "timeout",
                "failed"
              ]
            }
          },
          "additionalProperties": true
        },
        "state": {
          "type": "object",
          "additionalProperties": true
        },
        "observations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "examples": [
              {
                "type": "settle_response",
                "settle_status": "settled",
                "target": "url=/api/signup/validate-email",
                "matched_url": "https://example.com/api/signup/validate-email",
                "method": "POST",
                "status_code": 200,
                "url_includes": "/api/signup/validate-email"
              },
              {
                "type": "settle_item_count_change",
                "settle_status": "settled",
                "target": "selector=#signup-benefits li",
                "baseline_count": 1,
                "current_count": 3,
                "expected_count": 3,
                "count_delta": 2
              },
              {
                "observation_id": "step_002_checkpoint.obs_journey_action_raw",
                "type": "journey_action_raw",
                "stage": "CTA",
                "source": [
                  "scenario_log",
                  "dom",
                  "browser",
                  "network"
                ],
                "confidence": 0.8,
                "step_order": 2,
                "step_key": "step_002_checkpoint",
                "action_type": "click",
                "clicked_text": "무료로 시작하기",
                "clicked_selector": "a.hero-start",
                "url_before": "https://example.com",
                "url_after": "https://example.com/signup",
                "title_before": "Landing",
                "title_after": "Sign up",
                "dom_changed": true,
                "settle_status": "settled",
                "screenshot_artifact_id": "artifact-item-count-screenshot",
                "bbox": {
                  "x": 520,
                  "y": 360,
                  "width": 220,
                  "height": 56,
                  "unit": "css_px"
                }
              },
              {
                "observation_id": "step_002_checkpoint.obs_interactive_components",
                "type": "interactive_components",
                "stage": "CTA",
                "source": [
                  "dom",
                  "layout",
                  "screenshot"
                ],
                "confidence": 0.82,
                "primary_like_component_count": 1,
                "components": [
                  {
                    "text": "무료로 시작하기",
                    "selector": "a.hero-start",
                    "role": "link",
                    "tag": "a",
                    "clickable": true,
                    "clicked_in_scenario": true,
                    "is_cta_candidate": true,
                    "is_primary_like": true,
                    "bounds": {
                      "x": 520,
                      "y": 360,
                      "width": 220,
                      "height": 56,
                      "unit": "css_px"
                    }
                  }
                ]
              }
            ]
          },
          "examples": [
            [
              {
                "type": "settle_response",
                "settle_status": "settled",
                "target": "url=/api/signup/validate-email",
                "matched_url": "https://example.com/api/signup/validate-email",
                "method": "POST",
                "status_code": 200,
                "url_includes": "/api/signup/validate-email"
              }
            ],
            [
              {
                "type": "settle_item_count_change",
                "settle_status": "settled",
                "target": "selector=#signup-benefits li",
                "baseline_count": 1,
                "current_count": 3,
                "expected_count": 3,
                "count_delta": 2
              }
            ],
            [
              {
                "observation_id": "step_002_checkpoint.obs_interactive_components",
                "type": "interactive_components",
                "stage": "CTA",
                "source": [
                  "dom",
                  "layout",
                  "screenshot"
                ],
                "confidence": 0.82,
                "primary_like_component_count": 1,
                "components": [
                  {
                    "text": "무료로 시작하기",
                    "selector": "a.hero-start",
                    "role": "link",
                    "tag": "a",
                    "clickable": true,
                    "clicked_in_scenario": true,
                    "is_cta_candidate": true,
                    "is_primary_like": true,
                    "bounds": {
                      "x": 520,
                      "y": 360,
                      "width": 220,
                      "height": 56,
                      "unit": "css_px"
                    }
                  }
                ]
              }
            ]
          ]
        },
        "deltas": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "artifactRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stepKey": {
          "type": "string",
          "minLength": 1
        },
        "primaryStage": {
          "$ref": "#/$defs/DecisionStage",
          "deprecated": true,
          "description": "Deprecated alias retained for older runner callback producers. New runner callbacks should emit stage."
        }
      },
      "title": "Checkpoint",
      "examples": [
        {
          "checkpointId": "checkpoint-response-1",
          "stepKey": "step_003_fill_email",
          "stage": "INPUT",
          "trigger": {
            "stepOrder": 3,
            "actionType": "fill",
            "description": "테스트 이메일 입력"
          },
          "settle": {
            "strategy": "response",
            "durationMs": 216,
            "status": "settled"
          },
          "state": {
            "url": "https://example.com/signup",
            "title": "Sign up",
            "fields": {
              "Email": "test+wedge@example.com"
            }
          },
          "observations": [
            {
              "type": "form_field",
              "field_key": "Email",
              "value_length": 22
            },
            {
              "type": "settle_response",
              "settle_status": "settled",
              "target": "url=/api/signup/validate-email",
              "matched_url": "https://example.com/api/signup/validate-email",
              "method": "POST",
              "status_code": 200,
              "url_includes": "/api/signup/validate-email"
            },
            {
              "observation_id": "step_003_fill_email.obs_interactive_components",
              "type": "interactive_components",
              "stage": "CTA",
              "source": [
                "dom",
                "layout",
                "screenshot"
              ],
              "confidence": 0.82,
              "primary_like_component_count": 1,
              "components": [
                {
                  "text": "무료로 시작하기",
                  "selector": "a.hero-start",
                  "role": "link",
                  "tag": "a",
                  "clickable": true,
                  "clicked_in_scenario": false,
                  "is_cta_candidate": true,
                  "is_primary_like": true,
                  "bounds": {
                    "x": 520,
                    "y": 360,
                    "width": 220,
                    "height": 56,
                    "unit": "css_px"
                  }
                }
              ]
            }
          ],
          "deltas": [
            {
              "type": "last_action",
              "action": "fill",
              "target": "label_any=이메일|Email"
            }
          ],
          "artifactRefs": [
            "artifact-1",
            "artifact-2"
          ]
        }
      ]
    },
    "RunnerCheckpointsRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "checkpoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Checkpoint"
          }
        }
      },
      "required": [
        "checkpoints"
      ]
    },
    "DiscoveryAccepted": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string",
          "minLength": 1
        },
        "workerId": {
          "type": "string",
          "minLength": 1
        },
        "acceptedAt": {
          "type": "string",
          "format": "date-time"
        },
        "browserSessionId": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "eventId",
        "workerId",
        "acceptedAt",
        "browserSessionId"
      ]
    },
    "DiscoveryCheckpointRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string",
          "minLength": 1
        },
        "workerId": {
          "type": "string",
          "minLength": 1
        },
        "checkpoint": {
          "$ref": "#/$defs/Checkpoint"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "observations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "required": [
        "eventId",
        "workerId",
        "checkpoint",
        "artifacts",
        "observations"
      ]
    },
    "DiscoveryEvidenceSignal": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "signal_id": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": [
            "text",
            "aria_label",
            "aria_labelled_by_text",
            "label_text",
            "alt",
            "title",
            "href",
            "selector",
            "name",
            "placeholder",
            "form_field",
            "shallow_navigation"
          ]
        },
        "signal_type": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "evidence_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "weight": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "source",
        "value"
      ]
    },
    "DiscoveryEvidenceSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "matched_signals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DiscoveryEvidenceSignal"
          }
        },
        "missing_signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "matched_signals",
        "missing_signals",
        "limitations"
      ]
    },
    "DiscoverySummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "detectedFlowTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "LANDING_CTA",
              "SIGNUP_LEAD_FORM",
              "PRICING",
              "PURCHASE_CHECKOUT",
              "CONTACT",
              "CONTENT_ONLY"
            ]
          }
        },
        "missingFlowTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "LANDING_CTA",
              "SIGNUP_LEAD_FORM",
              "PRICING",
              "PURCHASE_CHECKOUT",
              "CONTACT",
              "CONTENT_ONLY"
            ]
          }
        },
        "primaryCtaCount": {
          "type": "integer",
          "minimum": 0
        },
        "formCandidateCount": {
          "type": "integer",
          "minimum": 0
        },
        "pricingEntrypointCount": {
          "type": "integer",
          "minimum": 0
        },
        "checkoutEntrypointCount": {
          "type": "integer",
          "minimum": 0
        },
        "scenarioRecommendations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "scenarioType": {
                "type": "string",
                "enum": [
                  "LANDING_CTA",
                  "SIGNUP_LEAD_FORM",
                  "PRICING",
                  "PURCHASE_CHECKOUT",
                  "CONTACT",
                  "CONTENT_ONLY",
                  "CUSTOM_GUIDED"
                ]
              },
              "recommendationLevel": {
                "type": "string",
                "enum": [
                  "HIGH",
                  "MEDIUM",
                  "LOW",
                  "NOT_AVAILABLE"
                ]
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "reason": {
                "type": "string"
              },
              "evidenceRefs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "evidenceSummary": {
                "anyOf": [
                  {
                    "$ref": "#/$defs/DiscoveryEvidenceSummary"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "suggestedStartUrl": {
                "type": "string",
                "format": "uri"
              },
              "suggestedTarget": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "required": [
              "scenarioType",
              "recommendationLevel",
              "confidence",
              "reason",
              "evidenceRefs"
            ]
          }
        }
      },
      "required": [
        "detectedFlowTypes",
        "missingFlowTypes",
        "scenarioRecommendations"
      ]
    },
    "DiscoveryFinished": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string",
          "minLength": 1
        },
        "workerId": {
          "type": "string",
          "minLength": 1
        },
        "finishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "finalUrl": {
          "type": "string",
          "format": "uri"
        },
        "summary": {
          "$ref": "#/$defs/DiscoverySummary"
        }
      },
      "required": [
        "eventId",
        "workerId",
        "finishedAt",
        "finalUrl",
        "summary"
      ]
    },
    "DiscoveryFailed": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string",
          "minLength": 1
        },
        "workerId": {
          "type": "string",
          "minLength": 1
        },
        "failedAt": {
          "type": "string",
          "format": "date-time"
        },
        "failureCode": {
          "type": "string",
          "minLength": 1
        },
        "failureMessage": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "eventId",
        "workerId",
        "failedAt",
        "failureCode",
        "failureMessage"
      ]
    },
    "AgentEventBatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "../schemas/agent-event.schema.json"
          }
        }
      },
      "required": [
        "events"
      ]
    },
    "AgentEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eventId": {
          "type": "string",
          "format": "uuid"
        },
        "taskId": {
          "type": "string",
          "minLength": 1
        },
        "attemptId": {
          "type": "string",
          "minLength": 1
        },
        "turn": {
          "type": "integer",
          "minimum": 1
        },
        "eventType": {
          "type": "string",
          "enum": [
            "PRE_DECISION_VERIFIED",
            "DECISION_MADE",
            "POLICY_CHECKED",
            "ACTION_COMPLETED",
            "ACTION_FAILED",
            "GOAL_VERIFIED",
            "TRACE_PERSISTED"
          ]
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
