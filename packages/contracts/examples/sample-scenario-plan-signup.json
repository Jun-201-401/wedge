{
  "schema_version": "0.5",
  "plan_id": "plan_signup_basic_001",
  "scenario_type": "template",
  "template_key": "signup_basic",
  "goal": "회원가입 CTA를 찾아 클릭하고 첫 입력 단계의 마찰을 점검한다.",
  "start_url": "https://example.com",
  "environment": {
    "device": "desktop",
    "viewport": {
      "width": 1440,
      "height": 900
    },
    "locale": "ko-KR",
    "timezone": "Asia/Seoul",
    "permissions": [],
    "auth_state": "anonymous"
  },
  "safety": {
    "allow_external_navigation": false,
    "allow_payment_commit": false,
    "allow_destructive_action": false,
    "use_synthetic_inputs": true,
    "stop_before_real_payment": true
  },
  "steps": [
    {
      "step_id": "step_001_goto",
      "stage": "FIRST_VIEW",
      "description": "랜딩 첫 화면 로드",
      "action": {
        "type": "goto",
        "target": "https://example.com"
      },
      "settle_strategy": {
        "type": "network_idle",
        "timeout_ms": 10000
      },
      "checkpoint": true
    },
    {
      "step_id": "step_002_click_signup",
      "stage": "CTA",
      "description": "회원가입 또는 무료 시작 CTA 클릭",
      "action": {
        "type": "click",
        "target": {
          "role": "button",
          "text_any": [
            "무료로 시작",
            "회원가입",
            "Start free"
          ]
        }
      },
      "settle_strategy": {
        "type": "locator_visible",
        "target": {
          "selector_any": [
            "input[type=email]",
            "form"
          ]
        },
        "timeout_ms": 8000
      },
      "checkpoint": true
    },
    {
      "step_id": "step_003_fill_email",
      "stage": "INPUT",
      "description": "테스트 이메일 입력",
      "action": {
        "type": "fill",
        "target": {
          "label_any": [
            "이메일",
            "Email"
          ]
        },
        "value": "test+wedge@example.com"
      },
      "settle_strategy": {
        "type": "response",
        "timeout_ms": 2000,
        "url_includes": "/api/signup/validate-email",
        "method": "POST",
        "status": 200
      },
      "checkpoint": true
    },
    {
      "step_id": "step_004_expand_benefits",
      "stage": "VALUE",
      "description": "혜택 목록 확장 후 항목 수 증가 확인",
      "action": {
        "type": "click",
        "target": {
          "role": "button",
          "text_any": [
            "혜택 보기",
            "See benefits"
          ]
        }
      },
      "settle_strategy": {
        "type": "item_count_change",
        "timeout_ms": 2000,
        "target": {
          "selector": "#signup-benefits li"
        },
        "expected_count": 3,
        "count_delta": 2
      },
      "checkpoint": true
    }
  ]
}
