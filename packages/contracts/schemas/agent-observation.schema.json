{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wedge.example.com/contracts/schemas/agent-observation.schema.json",
  "title": "Runner Agent Observation",
  "description": "MVP-compatible observation summary emitted inside AgentTrace turns. Rich candidate/locator fields may be added under additional properties as the observer matures.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "finalUrl": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string"
    },
    "candidateCount": {
      "type": "integer",
      "minimum": 0
    },
    "artifactRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": ["finalUrl", "title", "candidateCount"]
}
