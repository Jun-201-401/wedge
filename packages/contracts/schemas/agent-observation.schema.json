{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wedge.example.com/contracts/schemas/agent-observation.schema.json",
  "title": "Runner Agent Observation",
  "description": "Bounded, redacted observation summary emitted inside AgentTrace turns. Full DOM/AX/screenshot payloads remain artifacts; trace observations keep only explainable page and candidate metadata.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "finalUrl": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string"
    },
    "candidateCount": {
      "type": "integer",
      "minimum": 0
    },
    "visibleTextSample": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 200
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/AgentObservationCandidate"
      }
    },
    "formControls": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/AgentObservationFormControl"
      }
    },
    "pageSignals": {
      "$ref": "#/$defs/AgentObservationPageSignals"
    },
    "artifactRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": ["finalUrl", "title", "candidateCount"],
  "$defs": {
    "Bounds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "width": {
          "type": "number",
          "minimum": 0
        },
        "height": {
          "type": "number",
          "minimum": 0
        },
        "unit": {
          "enum": ["css_px", "screenshot_px", "viewport_ratio"]
        }
      },
      "required": ["x", "y", "width", "height", "unit"]
    },
    "AgentObservationCandidate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "candidateId": {
          "type": "string",
          "minLength": 1
        },
        "candidateFingerprint": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": ["string", "null"]
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string"
        },
        "inputType": {
          "type": ["string", "null"]
        },
        "labelText": {
          "type": ["string", "null"]
        },
        "placeholder": {
          "type": ["string", "null"]
        },
        "name": {
          "type": ["string", "null"]
        },
        "required": {
          "type": "boolean"
        },
        "disabled": {
          "type": "boolean"
        },
        "isFormControl": {
          "type": "boolean"
        },
        "clickable": {
          "type": "boolean"
        },
        "isCtaCandidate": {
          "type": "boolean"
        },
        "isPrimaryLike": {
          "type": "boolean"
        },
        "frameId": {
          "type": ["string", "null"]
        },
        "shadowRoot": {
          "type": "boolean"
        },
        "hrefOrigin": {
          "type": ["string", "null"]
        },
        "hrefPathHint": {
          "type": ["string", "null"]
        },
        "riskHint": {
          "type": ["string", "null"]
        },
        "bounds": {
          "$ref": "#/$defs/Bounds"
        }
      },
      "required": [
        "candidateId",
        "candidateFingerprint",
        "role",
        "tag",
        "text",
        "clickable",
        "isCtaCandidate",
        "isPrimaryLike",
        "frameId",
        "shadowRoot",
        "riskHint",
        "bounds"
      ]
    },
    "AgentObservationFormControl": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "controlKey": {
          "type": "string",
          "minLength": 1
        },
        "controlType": {
          "enum": ["field", "select"]
        },
        "hasValue": {
          "type": "boolean"
        }
      },
      "required": ["controlKey", "controlType", "hasValue"]
    },
    "AgentObservationPageSignals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "visitedUrlCount": {
          "type": "integer",
          "minimum": 0
        },
        "consoleErrorCount": {
          "type": "integer",
          "minimum": 0
        },
        "networkErrorCount": {
          "type": "integer",
          "minimum": 0
        },
        "breadcrumbCount": {
          "type": "integer",
          "minimum": 0
        },
        "toastCount": {
          "type": "integer",
          "minimum": 0
        },
        "visiblePriceCount": {
          "type": "integer",
          "minimum": 0
        },
        "productCardCount": {
          "type": "integer",
          "minimum": 0
        },
        "cartCount": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "hasLoginWallSignal": {
          "type": "boolean"
        },
        "hasCaptchaSignal": {
          "type": "boolean"
        },
        "hasPaymentOrCommitSignal": {
          "type": "boolean"
        }
      },
      "required": [
        "visitedUrlCount",
        "consoleErrorCount",
        "networkErrorCount",
        "breadcrumbCount",
        "toastCount",
        "visiblePriceCount",
        "productCardCount",
        "cartCount",
        "hasLoginWallSignal",
        "hasCaptchaSignal",
        "hasPaymentOrCommitSignal"
      ]
    }
  }
}
