{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wedge.example.com/contracts/schemas/evidence-packet.schema.json",
  "title": "Wedge EvidencePacket",
  "type": "object",
  "required": [
    "schema_version",
    "execution_type",
    "run_id",
    "url",
    "scenario",
    "environment",
    "checkpoints",
    "aggregate_signals",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "0.5"
    },
    "execution_type": {
      "enum": [
        "DISCOVERY",
        "RUN"
      ]
    },
    "run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "discovery_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "final_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "scenario": {
      "type": "object"
    },
    "environment": {
      "type": "object"
    },
    "checkpoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/checkpoint"
      }
    },
    "aggregate_signals": {
      "type": "object"
    },
    "scenario_fit": {
      "oneOf": [
        {
          "$ref": "#/$defs/scenario_fit"
        },
        {
          "type": "null"
        }
      ],
      "description": "Scenario applicability diagnostic. This is distinct from stage issues and does not by itself create a JudgeIssue."
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "collection_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decisionStageSummary": {
      "type": "object",
      "description": "Optional pre-Judge coverage summary by DecisionStage. It separates observation coverage from scenarioFitStatus and from JudgeResult DecisionMap status; it must not include issue-derived PASS/WARNING values.",
      "properties": {
        "FIRST_VIEW": {
          "$ref": "#/$defs/decision_stage_summary_item"
        },
        "VALUE": {
          "$ref": "#/$defs/decision_stage_summary_item"
        },
        "CTA": {
          "$ref": "#/$defs/decision_stage_summary_item"
        },
        "INPUT": {
          "$ref": "#/$defs/decision_stage_summary_item"
        },
        "COMMIT": {
          "$ref": "#/$defs/decision_stage_summary_item"
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "flow_type": {
      "enum": [
        "LANDING_CTA",
        "SIGNUP_LEAD_FORM",
        "PRICING",
        "PURCHASE_CHECKOUT",
        "CONTACT",
        "CONTENT_ONLY"
      ]
    },
    "scenario_fit_status": {
      "enum": [
        "UNKNOWN",
        "APPLICABLE",
        "LOW_CONFIDENCE",
        "NOT_APPLICABLE",
        "BLOCKED_BY_SITE",
        "UNSAFE_OR_RESTRICTED"
      ]
    },
    "scenario_fit": {
      "type": "object",
      "required": [
        "scenario_type",
        "scenario_fit_status",
        "reason",
        "evidence_refs",
        "recommended_alternatives"
      ],
      "properties": {
        "scenario_type": {
          "$ref": "#/$defs/flow_type"
        },
        "scenario_fit_status": {
          "$ref": "#/$defs/scenario_fit_status"
        },
        "reason": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended_alternatives": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/flow_type"
          }
        }
      },
      "additionalProperties": false
    },
    "checkpoint": {
      "type": "object",
      "required": [
        "checkpoint_id",
        "step_id",
        "primaryStage",
        "trigger",
        "settle",
        "state",
        "observations",
        "deltas",
        "artifact_refs"
      ],
      "properties": {
        "checkpoint_id": {
          "type": "string"
        },
        "step_id": {
          "type": "string"
        },
        "stage": {
          "$ref": "#/$defs/DecisionStage",
          "deprecated": true,
          "description": "Deprecated alias for primaryStage retained during migration. New producers should emit primaryStage."
        },
        "trigger": {
          "type": "object"
        },
        "settle": {
          "type": "object"
        },
        "state": {
          "$ref": "#/$defs/state"
        },
        "observations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/observation"
          }
        },
        "deltas": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "artifact_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "primaryStage": {
          "$ref": "#/$defs/DecisionStage",
          "description": "Primary stage of checkpoint based on scenario step/action context. A checkpoint can still contain observations assigned to other stages."
        }
      }
    },
    "state": {
      "type": "object",
      "properties": {
        "page": {
          "type": "object"
        },
        "dom_summary": {
          "type": "object"
        },
        "layout_summary": {
          "type": "object"
        },
        "visual_summary": {
          "type": "object"
        },
        "ax_summary": {
          "type": "object"
        },
        "network_summary": {
          "type": "object"
        },
        "console_summary": {
          "type": "object"
        },
        "performance_summary": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "observation": {
      "type": "object",
      "required": [
        "observation_id",
        "type",
        "stage",
        "source",
        "data"
      ],
      "properties": {
        "observation_id": {
          "type": "string"
        },
        "type": {
          "enum": [
            "heading_structure",
            "first_view_message",
            "cta_candidate",
            "cta_cluster",
            "interactive_components",
            "form_field",
            "form_error",
            "trust_signal",
            "visual_emphasis",
            "contrast_issue",
            "target_size_issue",
            "network_failure",
            "console_error",
            "settle_response",
            "settle_item_count_change",
            "journey_action_raw",
            "product_card",
            "product_detail_signal",
            "goal_action_candidate",
            "goal_action_result",
            "category_filter_signal",
            "depth_from_discovery",
            "text_block_metrics",
            "performance_metric",
            "scroll_delta",
            "flow_candidate",
            "entrypoint_candidate",
            "pricing_entrypoint",
            "checkout_entrypoint",
            "signup_entrypoint",
            "contact_entrypoint",
            "scenario_mismatch",
            "missing_entrypoint",
            "guided_scenario_hint",
            "other",
            "value_proposition",
            "feature_summary",
            "audience_signal",
            "cta_text_specificity",
            "required_field",
            "missing_label",
            "error_recovery",
            "submit_disabled",
            "final_submit_candidate",
            "pricing_condition",
            "risk_reduction_signal",
            "terms_privacy_signal",
            "payment_or_sensitive_action"
          ]
        },
        "stage": {
          "$ref": "#/$defs/DecisionStage",
          "description": "Decision moment related to this observation. It may differ from checkpoint.primaryStage, for example a CTA observation inside a FIRST_VIEW checkpoint."
        },
        "source": {
          "type": "array",
          "items": {
            "enum": [
              "dom",
              "layout",
              "screenshot",
              "ax",
              "network",
              "console",
              "performance",
              "discovery",
              "scenario_log",
              "rule"
            ]
          }
        },
        "data": {
          "type": "object"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": [
        "artifact_id",
        "type",
        "uri"
      ],
      "properties": {
        "artifact_id": {
          "type": "string"
        },
        "type": {
          "enum": [
            "frame",
            "screenshot",
            "dom_snapshot",
            "ax_tree",
            "trace",
            "har",
            "console_log",
            "report",
            "other"
          ]
        },
        "uri": {
          "type": "string"
        },
        "signed_url": {
          "type": "string",
          "format": "uri",
          "description": "Optional time-limited HTTP(S) URL for image-capable consumers such as Analyzer GMS screenshot checks."
        },
        "mime_type": {
          "type": "string"
        },
        "size_bytes": {
          "type": "integer"
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "DecisionStage": {
      "type": "string",
      "description": "Operational decision moment label. It is assigned from ScenarioPlan, checkpoint/action context, observation type, or StageResolver; not by LLM free-form judgment.",
      "enum": [
        "FIRST_VIEW",
        "VALUE",
        "CTA",
        "INPUT",
        "COMMIT"
      ]
    },
    "decision_stage_summary_item": {
      "type": "object",
      "required": [
        "status",
        "checkpointIds",
        "observationCount"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/EvidenceStageObservationStatus"
        },
        "checkpointIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "observationCount": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "description": "Pre-Judge coverage summary for a DecisionStage. This is not DecisionMap StageStatus and cannot include PASS or WARNING."
    },
    "EvidenceStageObservationStatus": {
      "type": "string",
      "description": "Pre-Judge observation coverage status for EvidencePacket decisionStageSummary. It cannot express issue-derived PASS/WARNING because RuleEngine has not run yet.",
      "enum": [
        "OBSERVED",
        "BLOCKED",
        "NOT_OBSERVED",
        "NOT_APPLICABLE"
      ]
    }
  }
}
