{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wedge.example.com/contracts/schemas/agent-trace.schema.json",
  "title": "Runner Agent Trace",
  "description": "MVP AgentTrace artifact. Stores explainable execution metadata only; no LLM chain-of-thought.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "0.1"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt_index": {
      "type": "integer",
      "minimum": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "turns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/AgentTurnTrace"
      }
    },
    "outcome": {
      "$ref": "agent-outcome.schema.json"
    }
  },
  "required": ["schema_version", "task_id", "attempt_id", "attempt_index", "run_id", "turns", "outcome"],
  "$defs": {
    "AgentTurnTrace": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "turn": {
          "type": "integer",
          "minimum": 1
        },
        "observation": {
          "$ref": "agent-observation.schema.json"
        },
        "preDecisionVerification": {
          "$ref": "agent-verification-result.schema.json"
        },
        "decision": {
          "$ref": "agent-decision.schema.json"
        },
        "policy": {
          "$ref": "agent-policy-result.schema.json"
        },
        "safetyBlock": {
          "$ref": "#/$defs/AgentSafetyBlock"
        },
        "actionResult": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "actionType": {
              "$ref": "scenario-plan.schema.json#/$defs/action/properties/type"
            },
            "finalUrl": {
              "type": "string",
              "minLength": 1
            },
            "completed": {
              "type": "boolean"
            }
          },
          "required": ["actionType", "finalUrl", "completed"]
        },
        "postActionVerification": {
          "$ref": "agent-verification-result.schema.json"
        }
      },
      "required": ["turn", "observation", "preDecisionVerification"]
    },
    "AgentSafetyBlock": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": ["scenario_safety"]
        },
        "safetyCode": {
          "type": "string",
          "enum": [
            "SYNTHETIC_INPUT_BLOCKED",
            "PAYMENT_COMMIT_BLOCKED",
            "DESTRUCTIVE_ACTION_BLOCKED",
            "EXTERNAL_NAVIGATION_BLOCKED",
            "EXTERNAL_VISIT_BLOCKED"
          ]
        },
        "riskClass": {
          "type": "string",
          "enum": [
            "SYNTHETIC_INPUT",
            "PAYMENT_COMMIT",
            "DESTRUCTIVE_ACTION",
            "EXTERNAL_NAVIGATION"
          ]
        },
        "reasonCode": {
          "$ref": "agent-outcome.schema.json#/properties/reason_code"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": ["source", "safetyCode", "riskClass", "reasonCode", "reason"]
    }
  }
}
