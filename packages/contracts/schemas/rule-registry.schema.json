{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wedge.example.com/contracts/schemas/rule-registry.schema.json",
  "title": "Wedge RuleRegistry",
  "type": "object",
  "required": [
    "schema_version",
    "registry_id",
    "rules"
  ],
  "properties": {
    "schema_version": {
      "const": "0.5"
    },
    "registry_id": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "axis": {
      "enum": [
        "Clarity",
        "Path",
        "Friction",
        "Trust",
        "Reliability",
        "Visual Integrity"
      ]
    },
    "evidence_level": {
      "enum": [
        "Standard",
        "Research-backed",
        "Expert Guide",
        "Operational",
        "Technical"
      ]
    },
    "source": {
      "enum": [
        "dom",
        "layout",
        "screenshot",
        "ax",
        "network",
        "console",
        "performance",
        "scenario_log"
      ]
    },
    "rule": {
      "type": "object",
      "required": [
        "criterion_id",
        "axis",
        "applicableStages",
        "evidence_level",
        "definition",
        "required_observations",
        "measurement_sources",
        "signal_rule",
        "severity_rules",
        "confidence_rule",
        "output_template"
      ],
      "properties": {
        "criterion_id": {
          "type": "string"
        },
        "axis": {
          "$ref": "#/$defs/axis"
        },
        "evidence_level": {
          "$ref": "#/$defs/evidence_level"
        },
        "definition": {
          "type": "string"
        },
        "required_observations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Observation types required by the rule. Equivalent conceptual name: requiredObservationTypes."
        },
        "measurement_sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source"
          }
        },
        "signal_rule": {
          "type": "string"
        },
        "severity_rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/severity_rule"
          }
        },
        "exceptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence_rule": {
          "type": "string",
          "description": "Confidence calculation rule. Confidence may increase when DOM, AX, layout, screenshot, network, or performance observations agree within the same StageContext."
        },
        "fix_leverage_default": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "output_template": {
          "type": "string"
        },
        "source_refs": {
          "type": "array",
          "deprecated": true,
          "description": "Legacy internal doc references. Use structured references for user-facing report badges.",
          "items": {
            "type": "string"
          }
        },
        "references": {
          "type": "array",
          "description": "Structured external basis metadata that can be copied to JudgeResult issues for report reference badges.",
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "applicableStages": {
          "type": "array",
          "minItems": 1,
          "description": "DecisionStage values where this rule is executed. The Rule Engine must not evaluate the rule against the whole page outside these StageContexts.",
          "items": {
            "$ref": "#/$defs/DecisionStage"
          },
          "uniqueItems": true
        },
        "stages": {
          "type": "array",
          "deprecated": true,
          "description": "Deprecated alias for applicableStages. New registries should use applicableStages.",
          "items": {
            "$ref": "#/$defs/DecisionStage"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "description": "A code-executable Judge rule. It evaluates only the StageContext entries listed in applicableStages and must output stage, axis, criterion, and evidenceRefs through Rule Engine results."
    },
    "reference": {
      "type": "object",
      "required": [
        "label",
        "publisher",
        "title",
        "basisSummary",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "publisher": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "basisSummary": {
          "type": "string",
          "description": "Short report-facing paraphrase of the cited basis. Do not store long copied excerpts here."
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "severity_rule": {
      "type": "object",
      "required": [
        "severity",
        "condition"
      ],
      "properties": {
        "severity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "condition": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "DecisionStage": {
      "type": "string",
      "description": "Operational decision moment label. Rules run only inside matching StageContext values.",
      "enum": [
        "FIRST_VIEW",
        "VALUE",
        "CTA",
        "INPUT",
        "COMMIT"
      ]
    }
  }
}
