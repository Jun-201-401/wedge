{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wedge.example.com/contracts/schemas/judge-result.schema.json",
  "title": "Wedge JudgeResult",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "evidence_schema_version",
    "rule_registry_id",
    "summary",
    "issues",
    "decision_map"
  ],
  "properties": {
    "schema_version": {
      "const": "0.5"
    },
    "run_id": {
      "type": "string"
    },
    "evidence_schema_version": {
      "type": "string"
    },
    "rule_registry_id": {
      "type": "string"
    },
    "summary": {
      "type": "object",
      "required": [
        "overall_risk",
        "friction_score",
        "top_issues_count",
        "task_success"
      ],
      "properties": {
        "overall_risk": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "friction_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "top_issues_count": {
          "type": "integer",
          "minimum": 0
        },
        "task_success": {
          "enum": [
            "success",
            "partial",
            "failed",
            "blocked"
          ]
        }
      }
    },
    "stage_scores": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stage_score"
      },
      "description": "Optional legacy/diagnostic aggregate. User-facing reports should prefer decision_map over stage-only score tables."
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/issue"
      }
    },
    "decision_map": {
      "type": "array",
      "description": "User journey Decision Map grouped by operational stage. Internal enum values are rendered with user-facing labels in UI.",
      "items": {
        "$ref": "#/$defs/decision_map_item"
      }
    },
    "scenario_mismatch_report": {
      "oneOf": [
        {
          "$ref": "#/$defs/scenario_mismatch_report"
        },
        {
          "type": "null"
        }
      ]
    },
    "nudges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nudge"
      }
    },
    "llm_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scenarioMismatchReport": {
      "oneOf": [
        {
          "$ref": "#/$defs/scenario_mismatch_report"
        },
        {
          "type": "null"
        }
      ],
      "description": "CamelCase alias for scenario_mismatch_report in API projections. Scenario mismatch is separate from JudgeIssue."
    }
  },
  "$defs": {
    "flow_type": {
      "enum": [
        "LANDING_CTA",
        "SIGNUP_LEAD_FORM",
        "PRICING",
        "PURCHASE_CHECKOUT",
        "CONTACT",
        "CONTENT_ONLY"
      ]
    },
    "scenario_fit_status": {
      "enum": [
        "UNKNOWN",
        "APPLICABLE",
        "LOW_CONFIDENCE",
        "NOT_APPLICABLE",
        "BLOCKED_BY_SITE",
        "UNSAFE_OR_RESTRICTED"
      ]
    },
    "scenario_mismatch_report": {
      "type": "object",
      "required": [
        "scenario_type",
        "scenario_fit_status",
        "block_reason",
        "evidence_refs",
        "recommended_alternatives",
        "user_message"
      ],
      "properties": {
        "scenario_type": {
          "$ref": "#/$defs/flow_type"
        },
        "scenario_fit_status": {
          "$ref": "#/$defs/scenario_fit_status"
        },
        "block_reason": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended_alternatives": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/flow_type"
          }
        },
        "user_message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "stage_score": {
      "type": "object",
      "required": [
        "stage",
        "score",
        "issue_count"
      ],
      "properties": {
        "stage": {
          "$ref": "#/$defs/DecisionStage"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "issue_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "issue": {
      "type": "object",
      "required": [
        "issue_id",
        "criterion_id",
        "stage",
        "axis",
        "severity",
        "confidence",
        "priority_score",
        "evidence_refs",
        "summary",
        "recommendations"
      ],
      "properties": {
        "issue_id": {
          "type": "string"
        },
        "criterion_id": {
          "type": "string"
        },
        "stage": {
          "$ref": "#/$defs/DecisionStage",
          "description": "DecisionStage assigned by Rule Engine based on StageContext. LLM cannot change it."
        },
        "axis": {
          "type": "string"
        },
        "severity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "priority_score": {
          "type": "number"
        },
        "evidence_level": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "problem_components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/problem_component"
          },
          "description": "Optional coordinate projection for report screenshot highlights. The source of truth remains evidence_refs and observations."
        },
        "observations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string"
        },
        "impact_hypothesis": {
          "type": "string"
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validation_questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exceptions_applied": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "description": "Judge issue produced by Rule Engine. issue.stage is assigned from StageContext; LLM cannot create a new stage or move the issue to another stage."
    },
    "problem_component": {
      "type": "object",
      "required": [
        "component_id",
        "evidence_ref",
        "coordinate_space",
        "bounding_box",
        "screenshot_artifact_id"
      ],
      "properties": {
        "component_id": {
          "type": "string"
        },
        "evidence_ref": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "selector": {
          "type": "string"
        },
        "coordinate_space": {
          "type": "string",
          "enum": [
            "viewport",
            "screenshot",
            "viewport_ratio"
          ]
        },
        "bounding_box": {
          "type": "object",
          "required": [
            "x",
            "y",
            "width",
            "height"
          ],
          "properties": {
            "x": {
              "type": "number"
            },
            "y": {
              "type": "number"
            },
            "width": {
              "type": "number"
            },
            "height": {
              "type": "number"
            },
            "unit": {
              "type": "string",
              "enum": [
                "css_px",
                "screenshot_px",
                "viewport_ratio"
              ]
            }
          },
          "additionalProperties": false
        },
        "viewport": {
          "type": "object",
          "required": [
            "width",
            "height"
          ],
          "properties": {
            "width": {
              "type": "number"
            },
            "height": {
              "type": "number"
            }
          },
          "additionalProperties": false
        },
        "screenshot_artifact_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "nudge": {
      "type": "object",
      "required": [
        "nudge_id",
        "issue_id",
        "title",
        "recommendation",
        "difficulty"
      ],
      "properties": {
        "nudge_id": {
          "type": "string"
        },
        "issue_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        },
        "recommendation": {
          "type": "string"
        },
        "difficulty": {
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH"
          ]
        },
        "expected_effect": {
          "type": "string"
        },
        "validation_question": {
          "type": "string"
        }
      }
    },
    "DecisionStage": {
      "type": "string",
      "description": "Operational decision moment label assigned by Rule Engine StageContext, not by LLM.",
      "enum": [
        "FIRST_VIEW",
        "VALUE",
        "CTA",
        "INPUT",
        "COMMIT"
      ]
    },
    "StageStatus": {
      "type": "string",
      "description": "Decision Map status for a stage. This is derived report state, not run lifecycle state.",
      "enum": [
        "OBSERVED",
        "PASS",
        "WARNING",
        "BLOCKED",
        "NOT_OBSERVED",
        "NOT_APPLICABLE"
      ]
    },
    "decision_map_item": {
      "type": "object",
      "required": [
        "stage",
        "displayName",
        "status",
        "issueIds",
        "summary",
        "evidenceRefs"
      ],
      "properties": {
        "stage": {
          "$ref": "#/$defs/DecisionStage"
        },
        "displayName": {
          "type": "string",
          "description": "User-facing label such as 첫 화면 이해, 가치 이해, 행동 선택, 입력 진행, 최종 확정."
        },
        "status": {
          "$ref": "#/$defs/StageStatus"
        },
        "issueIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
