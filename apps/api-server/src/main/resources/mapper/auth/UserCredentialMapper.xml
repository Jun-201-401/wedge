<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wedge.auth.infrastructure.UserCredentialMapper">
    <insert id="insert" parameterType="com.wedge.auth.domain.UserCredential">
        INSERT INTO user_credential (user_id, password_hash)
        VALUES (#{userId}, #{passwordHash})
    </insert>

    <select id="findPasswordHashByUserId" resultType="string">
        SELECT password_hash
        FROM user_credential
        WHERE user_id = #{userId}
    </select>
</mapper>
