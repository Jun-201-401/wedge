{
  "name": "@wedge/runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node runner scaffold for Wedge browser execution and callback delivery.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
