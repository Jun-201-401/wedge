{
  "name": "@wedge/runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node runner scaffold for Wedge browser execution and callback delivery.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node --experimental-strip-types src/index.ts",
    "dev": "node --experimental-strip-types src/index.ts",
    "test": "node --experimental-strip-types --test test/**/*.test.ts",
    "smoke:e2e": "node ../../infra/scripts/runner-e2e-smoke-suite.mjs",
    "smoke:discovery-targets": "node ../../infra/scripts/real-discovery-targets-smoke.mjs",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "amqplib": "^0.10.9",
    "playwright": "^1.59.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
